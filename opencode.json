{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia-nim/qwen/qwen3.5-397b-a17b",
  "small_model": "nvidia-nim/deepseek-ai/deepseek-v4-flash",
  "instructions": ["AGENTS.md", "SOUL.md", ".opencode/instructions/anti-hallucination.md"],

  "provider": {
    "nvidia-nim": {
      "name": "NVIDIA NIM (Free Endpoint Pool)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
        "moonshotai/kimi-k2.6": {
          "id": "moonshotai/kimi-k2.6",
          "name": "Kimi K2.6 (Мультимодальный флагман)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "multimodal-flagship",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95,
            "multimodal": true
          }
        },
        "minimaxai/minimax-m3": {
          "id": "minimaxai/minimax-m3",
          "name": "MiniMax M3 (Мультимодальный флагман)",
          "limit": { "context": 8192, "output": 4096 },
          "group": "multimodal-flagship",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95,
            "multimodal": true
          }
        },
        "z-ai/glm-5.1": {
          "id": "z-ai/glm-5.1",
          "name": "GLM 5.1 (Мультимодальный флагман)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "multimodal-flagship",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95
          }
        },
        "nvidia/nemotron-3-ultra-550b-a55b": {
          "id": "nvidia/nemotron-3-ultra-550b-a55b",
          "name": "Nemotron 3 Ultra (Рассуждения и мышление)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "reasoning-layer",
          "options": {
            "temperature": 0.1,
            "enable_thinking": true,
            "reasoning_budget": 16384
          }
        },
        "deepseek-ai/deepseek-v4-pro": {
          "id": "deepseek-ai/deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (Рассуждения и мышление)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "reasoning-layer",
          "options": {
            "temperature": 0.1,
            "thinking": false
          }
        },
        "deepseek-ai/deepseek-v4-flash": {
          "id": "deepseek-ai/deepseek-v4-flash",
          "name": "DeepSeek V4 Flash (Рассуждения и мышление)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "reasoning-layer",
          "options": {
            "temperature": 0.1,
            "thinking": true,
            "reasoning_effort": "high"
          }
        },
        "openai/gpt-oss-120b": {
          "id": "openai/gpt-oss-120b",
          "name": "GPT OSS 120B (Рассуждения и мышление)",
          "limit": { "context": 4096, "output": 2048 },
          "group": "reasoning-layer",
          "options": {
            "temperature": 0.1,
            "parse_reasoning_content": true
          }
        },
        "qwen/qwen3.5-397b-a17b": {
          "id": "qwen/qwen3.5-397b-a17b",
          "name": "Qwen 3.5 397B (Архитектурный кодинг)",
          "limit": { "context": 16384, "output": 8192 },
          "group": "architectural-coding",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95,
            "top_k": 20,
            "repetition_penalty": 1.0
          }
        },
        "mistralai/mistral-large-3-675b-instruct-2512": {
          "id": "mistralai/mistral-large-3-675b-instruct-2512",
          "name": "Mistral Large 3 (Архитектурный кодинг)",
          "limit": { "context": 2048, "output": 1024 },
          "group": "architectural-coding",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95
          }
        },
        "qwen/qwen3-next-80b-a3b-instruct": {
          "id": "qwen/qwen3-next-80b-a3b-instruct",
          "name": "Qwen 3 Next 80B (Архитектурный кодинг)",
          "limit": { "context": 4096, "output": 2048 },
          "group": "architectural-coding",
          "options": {
            "temperature": 0.1,
            "top_p": 0.95
          }
        }
      }
    }
  },

  "skills": {
    "paths": [".opencode/skills"]
  },

  "references": {
    "docs": {
      "path": ".",
      "description": "Project documentation and conventions"
    }
  },

  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },

  "plugin": [
    "opencode-vibeguard",
    "@bdliyq/opencode-rate-limit-retry@latest"
  ],

  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git diff --staged *": "allow",
      "git diff --unstaged *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "git push": "deny",
      "rm *": "deny",
      "rm -rf *": "deny",
      "trash *": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "mkdir *": "allow",
      "python *": "allow",
      "pytest *": "allow",
      "ruff *": "allow",
      "cargo *": "allow"
    },
    "external_directory": {
      "~/.ssh/**": "deny",
      "~/secrets/**": "deny",
      "*": "allow"
    }
  },

  "compaction": {
    "auto": true,
    "tail_turns": 8
  },

  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  }
}