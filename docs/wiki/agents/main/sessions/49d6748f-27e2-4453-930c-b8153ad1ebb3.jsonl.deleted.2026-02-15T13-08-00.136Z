{"type":"message","id":"9866d2b4","parentId":"b091bfc2","timestamp":"2026-02-15T12:08:28.917Z","message":{"role":"toolResult","toolCallId":"read_1771157308891_564","toolName":"read","content":[{"type":"text","text":"import subprocess\nimport os\nimport sys\nimport datetime\n\nROLLBACK_LOG = \"docs_archive/ROLLBACK_LOG.md\"\n\ndef log_rollback(action, status, details):\n    timestamp = datetime.datetime.now().isoformat()\n    entry = f\"| {timestamp} | {action} | {status} | {details} |\\n\"\n    \n    if not os.path.exists(ROLLBACK_LOG):\n        os.makedirs(os.path.dirname(ROLLBACK_LOG), exist_ok=True)\n        with open(ROLLBACK_LOG, \"w\") as f:\n            f.write(\"| Timestamp | Action | Status | Details |\\n|---|---|---|---|\\n\")\n    \n    with open(ROLLBACK_LOG, \"a\") as f:\n        f.write(entry)\n\ndef get_git_hash():\n    try:\n        return subprocess.check_output([\"git\", \"rev-parse\", \"HEAD\"]).decode().strip()\n    except:\n        return \"unknown\"\n\ndef run_tests():\n    # Running pytest. Assuming tests are discoverable.\n    result = subprocess.run([\"pytest\"], capture_output=True, text=True)\n    return result.returncode == 0, result.stdout + result.stderr\n\ndef safe_deploy(file_path, content):\n    initial_hash = get_git_hash()\n    print(f\"Starting safe deploy. Initial Hash: {initial_hash}\")\n    \n    # 1. Snapshot state (git stash to be safe, though instructions say commit hash)\n    # For this simple script, we will rely on git restore/clean if things fail.\n    # If the file is new, we track it to remove it.\n    \n    is_new_file = not os.path.exists(file_path)\n    \n    # 2. Apply change\n    os.makedirs(os.path.dirname(file_path), exist_ok=True)\n    with open(file_path, \"w\") as f:\n        f.write(content)\n        \n    print(f\"Applied changes to {file_path}\")\n\n    # 3. Run tests\n    print(\"Running tests...\")\n    success, output = run_tests()\n    \n    if success:\n        print(\"Tests passed. Change accepted.\")\n        log_rollback(f\"Deploy {file_path}\", \"SUCCESS\", \"Tests passed\")\n        # In a real scenario, we might commit here.\n    else:\n        print(\"Tests failed! Initiating rollback...\")\n        print(output) # Debug\n        \n        # 4. Rollback\n        if is_new_file:\n            os.remove(file_path)\n            print(f\"Rollback: Deleted new file {file_path}\")\n        else:\n            subprocess.run([\"git\", \"restore\", file_path])\n            print(f\"Rollback: Restored {file_path}\")\n            \n        log_rollback(f\"Deploy {file_path}\", \"ROLLBACK\", \"Tests failed\")\n\nif __name__ == \"__main__\":\n    # CLI usage: python src/deploy_safety.py <file_path> <content_string_or_file>\n    # For the test scenario, we will hardcode the broken logic test here if run directly without args,\n    # or accept args.\n    \n    if len(sys.argv) > 2:\n        path = sys.argv[1]\n        content = sys.argv[2]\n        safe_deploy(path, content)\n    else:\n        # Default test mode for the task\n        print(\"Running internal test scenario: 'Bad Code'...\")\n        broken_code = 'def broken_func(: print \"error\"' # Syntax error\n        safe_deploy(\"src/broken_logic.py\", broken_code)\n"}],"isError":false,"timestamp":1771157308916}}
