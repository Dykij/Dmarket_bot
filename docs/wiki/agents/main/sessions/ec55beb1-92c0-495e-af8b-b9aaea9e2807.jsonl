{"type":"message","id":"97208aea","parentId":"66acc25b","timestamp":"2026-02-14T09:00:57.698Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Defining the Architecture**\n\nI'm currently focused on defining the architecture for `src/logic/internal_arbitrage.py`. I've started outlining the `ArbitrageEngine` class and its core function, `calculate_pos_size(balance)`. My focus is on the requirements from ARKADY_CORE, with an initial position sizing logic of 20% if balance is less than 1000.\n\n\n"},{"type":"toolCall","id":"write_1771059657016_53","name":"write","arguments":{"content":"\"\"\"\nArbitrage Engine Module (SACS-2026 Compliant).\nImplements Triple Verification, Fractional Kelly Sizing, and Valve Reality Checks.\n\"\"\"\n\nimport logging\nimport math\nfrom typing import Dict, Tuple, Optional\n\n# Configure Logging\nlogger = logging.getLogger(\"logic.arbitrage\")\n# Ensure logs directory exists\nimport os\nos.makedirs(\"logs\", exist_ok=True)\ndecision_logger = logging.getLogger(\"arbitrage_decisions\")\ndecision_logger.setLevel(logging.INFO)\nfile_handler = logging.FileHandler(\"logs/arbitrage_decisions.log\")\nformatter = logging.Formatter('%(asctime)s - %(message)s')\nfile_handler.setFormatter(formatter)\ndecision_logger.addHandler(file_handler)\n\n\nclass ArbitrageEngine:\n    \"\"\"\n    The Brain of the Trading Operation.\n    Decides whether to BUY or PASS based on strict risk protocols.\n    \"\"\"\n\n    def __init__(self, balance: float):\n        self.balance = balance\n        self.risk_mode = \"AGGRESSIVE\" if balance < 50.0 else \"CONSERVATIVE\"\n\n    def calculate_pos_size(self, balance: float = None) -> float:\n        \"\"\"\n        Fractional Kelly Criterion for Position Sizing.\n        - Balance < $50: Max 20% (Turnover focus).\n        - Balance > $50: Max 10-15% (Risk mitigation).\n        \"\"\"\n        current_balance = balance if balance is not None else self.balance\n        \n        if current_balance < 50.0:\n            # High turnover needed to grow small account\n            size = current_balance * 0.20\n            logger.info(f\"Position Sizing (AGGRESSIVE): ${size:.2f} (20% of ${current_balance:.2f})\")\n            return size\n        else:\n            # Preservation mode\n            size = current_balance * 0.15\n            logger.info(f\"Position Sizing (CONSERVATIVE): ${size:.2f} (15% of ${current_balance:.2f})\")\n            return size\n\n    def get_real_cash_value(self, steam_price: float, wax_price: float) -> float:\n        \"\"\"\n        Calculates the 'Real' liquidation value of an item.\n        Formula: MIN(Steam * 0.70, Waxpeer).\n        We trust the lowest benchmark to be safe.\n        \"\"\"\n        steam_cash = steam_price * 0.70  # Steam Market - 30% (Fee + Cashout loss)\n        real_value = min(steam_cash, wax_price)\n        return real_value\n\n    def valve_reality_check(self, item_name: str) -> bool:\n        \"\"\"\n        Checks for recent nerfs or meta shifts.\n        In a live environment, this would query an LLM or a config file.\n        \"\"\"\n        # HARDCODED NERF LIST (Example)\n        # TODO: Connect to dynamic config or LLM query\n        NERFED_ITEMS = [\n            \"M4A1-S\",   # Often tweaked\n            \"AWP\",      # Magazine size changes\n        ]\n        \n        for nerfed in NERFED_ITEMS:\n            if nerfed in item_name:\n                decision_logger.warning(f\"Refused: Valve Nerf Risk ({item_name} contains {nerfed})\")\n                return False\n        \n        return True\n\n    def check_opportunity(\n        self, \n        item_name: str, \n        price_dm: float, \n        price_steam: float, \n        price_wax: float\n    ) -> Tuple[str, str]:\n        \"\"\"\n        The Golden Rule (Triple Verification).\n        Returns: (Decision \"BUY\"|\"PASS\", Reason)\n        \"\"\"\n        # 0. Valve Reality Check\n        if not self.valve_reality_check(item_name):\n            return \"PASS\", \"Valve Nerf Risk\"\n\n        # 1. Calculate Real Cash Value\n        real_value = self.get_real_cash_value(price_steam, price_wax)\n        \n        # 2. Triple Verification Logic\n        # Condition A: Profitable Flip vs Waxpeer\n        # We need at least 15% margin for fees/profit (0.85 multiplier)\n        cond_wax = price_dm < (price_wax * 0.85)\n        \n        # Condition B: Not Overpriced vs Steam\n        # We need to be below Steam * 0.68 to be safe against market crashes\n        cond_steam = price_dm < (price_steam * 0.68)\n        \n        # Condition C: Liquidity Trap\n        # Not checking volume here (assumed done by scanner), but checking price vs Real Value\n        cond_value = price_dm < real_value\n\n        # Logging Decision Factors\n        log_msg = (\n            f\"Item: {item_name} | DM: ${price_dm:.2f} | \"\n            f\"Wax: ${price_wax:.2f} (Target: <${price_wax*0.85:.2f}) | \"\n            f\"Steam: ${price_steam:.2f} (Target: <${price_steam*0.68:.2f}) | \"\n            f\"RealVal: ${real_value:.2f}\"\n        )\n\n        if cond_wax and cond_steam:\n            decision_logger.info(f\"APPROVED: {log_msg}\")\n            return \"BUY\", \"Triple Verification Passed\"\n        else:\n            reasons = []\n            if not cond_wax: reasons.append(\"Low Margin vs Wax\")\n            if not cond_steam: reasons.append(\"Overpriced vs Steam\")\n            \n            fail_reason = \", \".join(reasons)\n            decision_logger.warning(f\"Refused: {fail_reason} | {log_msg}\")\n            return \"PASS\", fail_reason\n\n# --- Integration Test ---\nif __name__ == \"__main__\":\n    # Test Scenario\n    engine = ArbitrageEngine(balance=45.50)\n    \n    # 1. Position Sizing Test\n    limit = engine.calculate_pos_size()\n    print(f\"Balance: $45.50 -> Max Bid: ${limit:.2f}\")\n\n    # 2. Decision Logic Test\n    # Case A: Good Deal (Rust Item)\n    # DM: $10, Wax: $13, Steam: $16\n    print(\"\\n--- Test Case A: Good Deal (Rust) ---\")\n    decision, reason = engine.check_opportunity(\n        item_name=\"Tempered Mask\", \n        price_dm=10.0, \n        price_steam=16.0, \n        price_wax=13.0\n    )\n    print(f\"Decision: {decision} ({reason})\")\n\n    # Case B: Bad Deal (Nerfed M4A1-S)\n    print(\"\\n--- Test Case B: Nerfed Item ---\")\n    decision, reason = engine.check_opportunity(\n        item_name=\"M4A1-S | Hyper Beast\", \n        price_dm=20.0, \n        price_steam=30.0, \n        price_wax=28.0\n    )\n    print(f\"Decision: {decision} ({reason})\")\n    \n    # Case C: Overpriced on DM\n    print(\"\\n--- Test Case C: Overpriced ---\")\n    decision, reason = engine.check_opportunity(\n        item_name=\"AK-47 | Redline\", \n        price_dm=15.0, \n        price_steam=20.0, \n        price_wax=16.0\n    )\n    print(f\"Decision: {decision} ({reason})\")\n","file_path":"D:\\DMarket-Telegram-Bot-main\\src\\logic\\internal_arbitrage.py"},"thoughtSignature":""},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-pro-preview","usage":{"input":60514,"output":2096,"cacheRead":55263,"cacheWrite":0,"totalTokens":62610,"cost":{"input":0.121028,"output":0.025152,"cacheRead":0.011052600000000001,"cacheWrite":0,"total":0.1572326}},"stopReason":"toolUse","timestamp":1771059636735}}
