\"Price too low\"\n        assert game in GAME_IDS, f\"Invalid Game ID: {game}\"\n        assert len(offer_id) > 5, \"Invalid Offer ID\"\n    except AssertionError as e:\n        logger.error(f\"INPUT VALIDATION FAILED: {e}\")\n        sys.exit(1)\n\n    # 2. LIVE MARKET CHECK (Race Condition Prevention)\n    # In a real scenario, we'd fetch the specific offer again to ensure it's still there\n    # and the price hasn't changed.\n    # For this implementation, we assume the data passed is fresh from the scanner.\n    \n    # 3. TRIPLE VERIFICATION (The \"Lobster\" Asserts)\n    # We re-run the logic engine to be 100% sure.\n    engine = ArbitrageEngine(balance=50.0) # Balance handled dynamically usually\n    decision, reason = engine.check_opportunity(\n        item_name=item_title,\n        price_dm=target_price_usd,\n        price_steam=steam_price_ref,\n        price_wax=wax_price_ref\n    )\n\n    if decision != \"BUY\":\n        logger.warning(f\"LOGIC ASSERT FAILED: {reason}\")\n        sys.exit(1) # TERMINATE\n\n    # 4. EXECUTION (The only place API is called)\n    public_key = os.getenv(\"DMARKET_PUBLIC_KEY\")\n    secret_key = os.getenv(\"DMARKET_SECRET_KEY\")\n    \n    if os.getenv(\"DRY_RUN\", \"true\").lower() == \"true\":\n        logger.info(\"DRY RUN: Buy Verified but NOT Executed.\")\n        sys.exit(0)\n\n    try:\n        api = DMarketAPI(public_key, secret_key)\n        \n        # CONVERT TO CENTS (Vital Fix from Docs)\n        price_coins = int(target_price_usd * 100)\n        \n        logger.info(f\"EXECUTING BUY API: {offer_id} @ {price_coins} coins\")\n        response = await api.buy_item(offer_id, price_coins, game=game)\n        \n        if response.get(\"status\") == \"success\" or \"txId\" in response:\n             logger.info(f\"BUY SUCCESS: {response}\")\n        else:\n             logger.error(f\"BUY API ERROR: {response}\")\n             \n        await api.close()\n\n    except Exception as e:\n        logger.critical(f\"EXECUTION ERROR: {e}\")\n        sys.exit(1)\n\nif __name__ == \"__main__\":\n    # CLI Interface for OpenClaw to call\n    # Usage: python safe_buy.py <game> <title> <price> <offer_id> <steam_ref> <wax_ref>\n    if len(sys.argv) < 7:\n        print(\"Usage: python safe_buy.py <game> <title> <price> <offer_id> <steam_ref> <wax_ref>\")\n        sys.exit(1)\n        \n    asyncio.run(safe_buy_workflow(\n        game=sys.argv[1],\n        item_title=sys.argv[2],\n        target_price_usd=float(sys.argv[3]),\n        offer_id=sys.argv[4],\n        steam_price_ref=float(sys.argv[5]),\n        wax_price_ref=float(sys.argv[6])\n    ))\n","file_path":"D:\\DMarket-Telegram-Bot-main\\workflows\\safe_buy.py"},"thoughtSignature":"EiYKJGUyNDgzMGE3LTVjZDYtNDJmZS05OThiLWVlNTM5ZTcyYjljMw=="},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-pro-preview","usage":{"input":108153,"output":1379,"cacheRead":104728,"cacheWrite":0,"totalTokens":109532,"cost":{"input":0.216306,"output":0.016548,"cacheRead":0.0209456,"cacheWrite":0,"total":0.2537996}},"stopReason":"toolUse","timestamp":1771060154795}}
