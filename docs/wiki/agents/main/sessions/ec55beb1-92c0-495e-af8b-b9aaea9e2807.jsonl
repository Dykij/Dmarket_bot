ent\": [ { \"name\": \"Install PowerShell on Windows\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/install/installing-powershell-on-windows\" }, { \"name\": \"Install PowerShell on Linux\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/install/installing-powershell-on-linux\" }, { \"name\": \"Install PowerShell on macOS\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/install/installing-powershell-on-macos\" }, { \"name\": \"What's new in PowerShell\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/whats-new/what-s-new-in-powershell-74\" } ] }, { \"id\": \"utility_modules\", \"title\": \"PowerShell Utility Modules\", \"content\": [ { \"name\": \"Crescendo\", \"url\": \"https://learn.microsoft.com/en-us/powershell/utility-modules/crescendo/overview\", \"description\": \"Create PowerShell cmdlets from native commands.\" }, { \"name\": \"PlatyPS\", \"url\": \"https://learn.microsoft.com/en-us/powershell/utility-modules/platyps/overview\", \"description\": \"Help documentation management.\" }, { \"name\": \"PSScriptAnalyzer\", \"url\": \"https://learn.microsoft.com/en-us/powershell/utility-modules/psscriptanalyzer/overview\", \"description\": \"Static code analysis.\" }, { \"name\": \"SecretManagement\", \"url\": \"https://learn.microsoft.com/en-us/powershell/utility-modules/secretmanagement/overview\", \"description\": \"Secret/credential management.\" } ] }, { \"id\": \"dsc\", \"title\": \"Desired State Configuration (DSC)\", \"content\": { \"description\": \"Management framework for managing enterprise infrastructure with configuration as code.\", \"capabilities\": [ \"Create declarative configurations and custom scripts for repeatable deployments\", \"Enforce configuration settings and report on configuration drift\", \"Deploy configuration using push or pull models\" ], \"versions\": [ { \"name\": \"Microsoft DSC 3.0\", \"url\": \"https://learn.microsoft.com/en-us/powershell/dsc/overview?view=dsc-3.0\" }, { \"name\": \"PowerShell DSC 2.0\", \"url\": \"https://learn.microsoft.com/en-us/powershell/dsc/overview?view=dsc-2.0\" }, { \"name\": \"PowerShell DSC 1.1\", \"url\": \"https://learn.microsoft.com/en-us/powershell/dsc/overview?view=dsc-1.1\" } ] } }, { \"id\": \"automation\", \"title\": \"Automation Platform\", \"content\": { \"microsoft_modules\": [ { \"name\": \"Azure\", \"url\": \"https://learn.microsoft.com/en-us/powershell/azure\" }, { \"name\": \"Windows\", \"url\": \"https://learn.microsoft.com/en-us/powershell/windows/get-started\" }, { \"name\": \"Exchange\", \"url\": \"https://learn.microsoft.com/en-us/powershell/exchange/exchange-management-shell\" }, { \"name\": \"SQL\", \"url\": \"https://learn.microsoft.com/en-us/sql/powershell/sql-server-powershell\" } ], \"third_party_modules\": [ { \"name\": \"AWS\", \"url\": \"https://aws.amazon.com/powershell/\" }, { \"name\": \"VMware\", \"url\": \"https://developer.broadcom.com/powercli\" }, { \"name\": \"Google Cloud\", \"url\": \"https://cloud.google.com/powershell/\" } ] } }, { \"id\": \"developer_resources\", \"title\": \"Developer Resources\", \"content\": [ { \"name\": \"VS Code PowerShell Extension\", \"url\": \"https://code.visualstudio.com/docs/languages/powershell\" }, { \"name\": \"VS Code remote editing and debugging\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/components/vscode/using-vscode-for-remote-editing-and-debugging\" }, { \"name\": \"PowerShell SDK documentation\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/developer/windows-powershell\" }, { \"name\": \"PowerShell SDK API reference\", \"url\": \"https://learn.microsoft.com/en-us/dotnet/api/?view=powershellsdk-7.4.0\" } ] }, { \"id\": \"getting_started\", \"title\": \"Getting Started\", \"content\": [ { \"name\": \"Install PowerShell\", \"url\": \"https://learn.microsoft.com/en-us/powershell/scripting/install/installing-powershell\" }, { \"name\": \"Discover PowerShell\", 