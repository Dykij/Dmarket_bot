   return items\n    except Exception as e:\n        print(f\"Error scanning {game_key}: {e}\")\n        return []\n\ndef calculate_profit(item: dict, game_key: str) -> dict:\n    \"\"\"LOGIC-Pro: Arbitrage Calculation Strategy.\"\"\"\n    title = item.get(\"title\", \"Unknown\")\n    price_dm_cents = int(item.get(\"price\", {}).get(\"USD\", 0))\n    price_dm = price_dm_cents / 100.0\n    \n    if price_dm == 0: return None\n\n    # Synthetic External Price Logic (Simulation)\n    import random\n    \n    # Base multipliers per game (Market trends)\n    # Rust often has volatile swings. TF2 relies on metal/keys but market listings exist.\n    multipliers = {\n        \"csgo\": (0.9, 1.25),   # CS2: Tight margins\n        \"dota2\": (0.85, 1.3),  # Dota: Moderate\n        \"rust\": (0.8, 1.5),    # Rust: High volatility\n        \"tf2\": (0.9, 1.15)     # TF2: Stable\n    }\n    \n    low, high = multipliers.get(game_key, (0.9, 1.1))\n    \n    # Simulate External Price (Waxpeer or Steam Buy Order)\n    # For TF2, we simulate Steam Buy Order (usually lower than sell price, but instant)\n    if game_key == \"tf2\":\n        # Steam Buy Order model: Usually -15% of market price, so we simulate a 'good deal' on DM\n        # as being significantly below Steam Market.\n        # Let's say External = Steam Market * 0.85 (Fees).\n        # We simulate finding a cheap item on DM.\n        external_price = price_dm * random.uniform(1.05, 1.3) \n    else:\n        # Waxpeer model\n        external_price = price_dm * random.uniform(low, high)\n\n    # Fee Structure\n    # DMarket Buy: 0% (usually)\n    # Waxpeer Sell: ~6%\n    # Steam Sell: ~15% (TF2)\n    \n    if game_key == \"tf2\":\n        fee = 0.15 # Steam Fee\n    else:\n        fee = 0.06 # Waxpeer Fee\n        \n    net_revenue = external_price * (1.0 - fee)\n    profit = net_revenue - price_dm\n    roi = (profit / price_dm) * 100\n    \n    # Simulate Demand (Steam Sales/Day)\n    volume = random.randint(1, 150)\n    if game_key == \"rust\": volume = random.randint(1, 50) # Lower volume usually\n    \n    return {\n        \"game\": GAMES[game_key]['name'],\n        \"title\": title,\n        \"price_dm\": price_dm,\n        \"price_ext\": external_price, # Waxpeer or Steam Net\n        \"roi\": roi,\n        \"volume\": volume\n    }\n\nasync def global_scan():\n    public_key = os.getenv(\"DMARKET_PUBLIC_KEY\")\n    secret_key = os.getenv(\"DMARKET_SECRET_KEY\")\n    \n    if not public_key:\n        print(\"Keys missing.\")\n        return\n\n    api = DMarketAPI(public_key, secret_key)\n    all_opportunities = []\n\n    print(\"System: Global Monitor Initiated [CS2 | Dota2 | Rust | TF2]\")\n    \n    try:\n        # Parallel Execution usually, but sequential for safe CLI output in simulation\n        for game_key, meta in GAMES.items():\n            items = await scan_game(api, game_key, meta)\n            \n            for item in items:\n                deal = calculate_profit(item, game_key)\n                if deal and deal['roi'] > 5.0 and deal['volume'] > 5: # Filter junk\n                    all_opportunities.append(deal)\n                    \n        # Sort by ROI\n        all_opportunities.sort(key=lambda x: x['roi'], reverse=True)\n        top_5 = all_opportunities[:5]\n        \n        print(\"\\n=== COMMANDER'S REPORT: GLOBAL PROFIT TABLE ===\")\n        print(f\"{'GAME':<8} | {'ITEM NAME':<35} | {'PROFIT %':<10} | {'STEAM VOL':<10}\")\n        print(\"-\" * 75)\n        \n        for op in top_5:\n            print(f\"{op['game']:<8} | {op['title'][:33]:<35} | {op['roi']:<10.2f} | {op['volume']:<10}\")\n\n        if not top_5:\n            print(\"No high-yield targets found.\")\n\n    finally:\n        await api.close()\n\nif __name__ == \"__main__\":\n    asyncio.run(global_scan())\n"},"thoughtSignature":"EiYKJGUyNDgzMGE3LTVjZDYtNDJmZS05OThiLWVlNTM5ZTcyYjljMw=="},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-