{"type":"message","id":"eb9b1d76","parentId":"1ba25d9a","timestamp":"2026-02-14T09:16:13.621Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write_1771060573615_4","name":"write","arguments":{"content":"\"\"\"\nLiquidity Queue Module (Redis Integration).\nImplements a Priority Queue using Redis Sorted Sets (ZADD/ZPOPMIN) for high-speed arbitrage.\n\"\"\"\n\nimport logging\nimport json\nfrom typing import Optional, List, Tuple\n# In a real deployment, we'd use `redis` library.\n# For now, we simulate the interface or assume redis-py is installed.\ntry:\n    import redis\n    HAS_REDIS = True\nexcept ImportError:\n    HAS_REDIS = False\n\nlogger = logging.getLogger(\"logic.liquidity_queue\")\n\nclass LiquidityQueue:\n    \"\"\"\n    Manages the 'Hot List' of arbitrage opportunities.\n    Uses Redis Sorted Sets to keep the highest ROI items at the top.\n    \"\"\"\n    \n    def __init__(self, host='localhost', port=6379, db=0):\n        self.enabled = HAS_REDIS\n        if self.enabled:\n            try:\n                self.client = redis.Redis(host=host, port=port, db=db, decode_responses=True)\n                self.client.ping()\n                logger.info(\"Redis Connection Established.\")\n            except Exception as e:\n                logger.warning(f\"Redis Connection Failed: {e}. Running in Memory Mode.\")\n                self.enabled = False\n        \n        self.memory_queue = [] # Fallback for non-Redis environments\n\n    def push_opportunity(self, item_id: str, roi: float, metadata: dict):\n        \"\"\"\n        Add an item to the queue.\n        Score = ROI (Higher is better, so we might use negative for ZPOPMIN or standard for ZPOPMAX).\n        We'll use ZADD with ROI as score. To pop highest, we use ZPOPMAX.\n        \"\"\"\n        payload = json.dumps(metadata)\n        member = f\"{item_id}::{payload}\" # Composite key for simple retrieval\n        \n        if self.enabled:\n            try:\n                # ZADD key score member\n                self.client.zadd(\"liquidity_queue\", {member: roi})\n                logger.info(f\"Redis: Pushed {item_id} with ROI {roi}%\")\n            except Exception as e:\n                logger.error(f\"Redis Push Error: {e}\")\n        else:\n            self.memory_queue.append((roi, member))\n            self.memory_queue.sort(key=lambda x: x[0], reverse=True)\n\n    def pop_best_opportunity(self) -> Optional[Tuple[str, float, dict]]:\n        \"\"\"\n        Get the highest ROI item and remove it from queue.\n        Returns: (item_id, roi, metadata)\n        \"\"\"\n        if self.enabled:\n            try:\n                # ZPOPMAX key [count]\n                result = self.client.zpopmax(\"liquidity_queue\")\n                if not result:\n                    return None\n                \n                member, score = result[0]\n                item_id, payload_str = member.split(\"::\", 1)\n                metadata = json.loads(payload_str)\n                return item_id, score, metadata\n            except Exception as e:\n                logger.error(f\"Redis Pop Error: {e}\")\n                return None\n        else:\n            if not self.memory_queue:\n                return None\n            roi, member = self.memory_queue.pop(0)\n            item_id, payload_str = member.split(\"::\", 1)\n            metadata = json.loads(payload_str)\n            return item_id, roi, metadata\n\n    def get_queue_length(self) -> int:\n        if self.enabled:\n            return self.client.zcard(\"liquidity_queue\")\n        return len(self.memory_queue)\n\n# --- Integration Test ---\nif __name__ == \"__main__\":\n    # Simulate Usage\n    queue = LiquidityQueue()\n    \n    print(\"--- Pushing Opportunities ---\")\n    queue.push_opportunity(\"item_1\", 15.5, {\"name\": \"AK-47 | Redline\", \"price\": 10.0})\n    queue.push_opportunity(\"item_2\", 25.0, {\"name\": \"Rust | Christmas Lights\", \"price\": 15.0})\n    queue.push_opportunity(\"item_3\", 5.0,  {\"name\": \"AWP | Safari Mesh\", \"price\": 0.5})\n    \n    print(f\"Queue Length: {queue.get_queue_length()}\")\n    \n    print(\"\\n--- Popping Best Deal ---\")\n    best = queue.pop_best_opportunity()\n    if best:\n        item_id, roi, meta = best\n        print(f\"Winner: {meta['name']} (ROI: {roi}%)\")\n    \n    print(\"\\n--- Popping Next Best ---\")\n    next_best = queue.pop_best_opportunity()\n    if next_best:\n        item_id, roi, meta = next_best\n        print(f\"Runner Up: {meta['name']} (ROI: {roi}%)\")\n","file_path":"D:\\DMarket-Telegram-Bot-main\\src\\logic\\liquidity_queue.py"},"thoughtSignature":"EiYKJGUyNDgzMGE3LTVjZDYtNDJmZS05OThiLWVlNTM5ZTcyYjljMw=="},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-pro-preview","usage":{"input":111378,"output":1204,"cacheRead":108872,"cacheWrite":0,"totalTokens":112582,"cost":{"input":0.22275599999999998,"output":0.014448,"cacheRead":0.021774400000000003,"cacheWrite":0,"total":0.2589784}},"stopReason":"toolUse","timestamp":1771060561655}}
