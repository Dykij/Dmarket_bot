eded) or a safe relative path like MEDIA:./image.jpg. Avoid absolute paths (MEDIA:/...) and ~ paths — they are blocked for security. Keep caption in the text body.\n[Telegram Бодичка (@Gudian1233) id:458765683 +0s 2026-02-14 11:06 GMT+2] <media:document> <file name=\"file_16---f3410ba2-4426-46a2-be36-cbbb008b699d.json\" mime=\"application/json\"> { \"title\": \"DMarket Trading API Documentation\", \"metadata\": { \"source\": \"https://docs.dmarket.com/v1/swagger.json\", \"generated_at\": \"2026-02-11T13:14:44.778817Z\", \"version\": \"v1.0.0-oas3\", \"base_url\": \"https://api.dmarket.com\", \"description\": \"DMarket Trading API enables managing DMarket inventory for in-game items (CS2, Dota 2, TF2, Rust).\" }, \"sections\": [ { \"id\": \"authentication\", \"title\": \"Authentication\", \"content\": { \"description\": \"Requests require 3 headers: X-Api-Key (public key hex), X-Sign-Date (timestamp), X-Request-Sign (SHA256/ed25519 signature).\", \"signature_steps\": [ \"1. Build non-signed string: (HTTP Method) + (Route path + HTTP query params) + (body string) + (timestamp)\", \"2. Sign with NACL using your secret key\", \"3. Encode the result string with hex\", \"4. Add signature to X-Request-Sign header (dmar ed25519 signature)\" ], \"tools_repo\": \"https://github.com/dmarket/dm-trading-tools\", \"api_keys_settings\": \"https://dmarket.com/faq#tradingAPI\" } }, { \"id\": \"account\", \"title\": \"Account\", \"content\": { \"endpoints\": [ { \"method\": \"GET\", \"path\": \"/account/v1/user\", \"summary\": \"Getting general user profile information.\" }, { \"method\": \"GET\", \"path\": \"/account/v1/balance\", \"summary\": \"Getting current USD & DMC balance (format: coins/cents).\" } ] } }, { \"id\": \"sell_items\", \"title\": \"Sell Items\", \"content\": { \"endpoints\": [ { \"method\": \"POST\", \"path\": \"/marketplace-api/v1/deposit-assets\", \"summary\": \"Transfer items from 3rd party inventory (e.g. Steam) to DMarket inventory.\" }, { \"method\": \"GET\", \"path\": \"/marketplace-api/v1/deposit-status/{DepositID}\", \"summary\": \"Get information about current deposit transfers.\" }, { \"method\": \"GET\", \"path\": \"/marketplace-api/v1/user-offers\", \"summary\": \"Get user's offers list for management (remove/change price). Price in USD.\" }, { \"method\": \"POST\", \"path\": \"/marketplace-api/v1/user-offers/create\", \"summary\": \"Batch offers creation. Asset is locked and offer appears in Market. Price in USD.\" }, { \"method\": \"POST\", \"path\": \"/marketplace-api/v1/user-offers/edit\", \"summary\": \"Change sale price for existing offers. Price in USD.\" } ], \"game_ids\": { \"CS:GO\": \"a8db\", \"Team Fortress 2\": \"tf2\", \"Dota 2\": \"9a92\", \"Rust\": \"rust\" } } }, { \"id\": \"buy_items\", \"title\": \"Buy Items\", \"content\": { \"endpoints\": [ { \"method\": \"GET\", \"path\": \"/exchange/v1/offers-by-title\", \"summary\": \"Get all offers for a single item title. Price in USD.\" }, { \"method\": \"GET\", \"path\": \"/price-aggregator/v1/aggregated-prices\", \"summary\": \"Get best market prices grouped by item title.\" }, { \"method\": \"POST\", \"path\": \"/exchange/v1/offers/buy\", \"summary\": \"Buy selected offers. Price in coins (cents for USD).\" }, { \"method\": \"GET\", \"path\": \"/marketplace-api/v1/user-offers/closed\", \"summary\": \"Get user's closed sell offers. Price in USD.\" } ] } }, { \"id\": \"inventory\", \"title\": \"Inventory/Items\", \"content\": { \"endpoints\": [ { \"method\": \"GET\", \"path\": \"/marketplace-api/v1/user-inventory\", \"summary\": \"Get user inventory (Steam + DMarket merged). Price in USD.\" }, { \"method\": \"POST\", \"path\": \"/marketplace-api/v1/user-inventory/sync\", \"summary\": \"Sync DMarket inventory with Steam data.\" }, { \"method\": \"POST\", \"path\": \"/exchange/v1/withdraw-assets\", \"summary\": \"Withdraw assets from DMarket.\" }, { \"method\": \"GET\", \"path\": \"/exchange/v1/user/items\", \"summary\": \"Get user inventory filtered by game (excludes items on sale).\" } ] } }, { \"id\": \"supported_games\", \"title\": \"Supported Games\", \"content\": [ \"CS:GO (CS2)\", \"Dota 2\", \"Team Fortress 2\", \"Rust\" ] }, { \"id\": \"error_codes\", \"title\": \"Error Codes\", \"content\": [ \"BadRequest\", \"Unauthorized\", \"Forbidden\", \"NotFound\", \"Conflict\", \"InternalServerError\", \"InvalidSignature\", \"InvalidAPIKey\", \"APIKeyDisabled\", \"AccountDepositThresholdLimitExceeded\", \"InvalidAmount\", \"DeprecatedArguments\" ] } ] } </file> <file name=\"file_17---5f13c2b1-5267-4afa-9891-7f1d214c89eb.json\" mime=\"application/json\"> { \"title\": \"GitHub Documentation\", \"metadata\": { \"source\": \"https://docs.github.com/en\", \"generated_at\": \"2026-02-11T13:14:44.778817Z\", \"description\": \"Complete documentation for GitHub platform.\" }, \"sections\": [ { \"id\": \"get_started\", \"title\": \"Get Started\", \"content\": [ { \"name\": \"Get started\", \"url\": \"https://docs.github.com/en/get-started\" }, { \"name\": \"Migrations\", \"url\": \"https://docs.github.com/en/migrations\" }, { \"name\": \"Account and profile\", \"url\": \"https://docs.github.com/en/account-and-profile\" }, { \"name\": \"Authentication\", \"url\": \"https://docs.github.com/en/authentication\" }, { \"name\": \"Billing and payments\", \"url\": \"https://docs.github.com/en/billing\" }, { \"name\": \"Set up Git\", \"url\": \"https://docs.github.com/en/get-started/git-basics/set-up-git\", \"description\": \"Git is responsible for everything GitHub-related that happens locally on your computer.\" }, { \"name\": \"Connecting to GitHub with SSH\", \"url\": \"https://docs.github.com/en/authentication/connecting-to-github-with-ssh\", \"description\": \"Connect using the Secure Shell Protocol (SSH).\" }, { \"name\": \"Creating and managing repositories\", \"url\": \"https://docs.github.com/en/repositories/creating-and-managing-repositories\" }, { \"name\": \"Basic writing and formatting syntax\", \"url\": \"https://docs