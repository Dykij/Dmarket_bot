{"type":"message","id":"e4163c58","parentId":"c338506b","timestamp":"2026-02-15T13:19:47.335Z","message":{"role":"toolResult","toolCallId":"read_1771161587311_95","toolName":"read","content":[{"type":"text","text":"import sys\nimport os\nimport subprocess\nimport argparse\nimport signal\nimport time\nimport threading\nimport json\n\nPID_FILE = \"src/bot.pid\"\nBOT_SCRIPT = \"src/trading_bot.py\"\nPROTOCOL_FILE = \"docs_archive/MASTER_PROTOCOL.md\"\nCONFIG_FILE = \"openclaw.json\"\n\nFLEET_GAMES = [\"CS2\", \"Rust\", \"TF2\"]\n\ndef load_config():\n    \"\"\"Load config from openclaw.json.\"\"\"\n    if os.path.exists(CONFIG_FILE):\n        try:\n            with open(CONFIG_FILE, 'r') as f:\n                return json.load(f)\n        except Exception as e:\n            print(f\"Error loading config: {e}\")\n    return {}\n\ndef reload_protocol():\n    \"\"\"Reloads the master protocol configuration.\"\"\"\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Hot Reload: Active\")\n    # In a real implementation, this would signal the bot process or reload config\n    # For now, we just log as requested.\n\ndef monitor_protocol():\n    \"\"\"Monitors the protocol file for changes.\"\"\"\n    if not os.path.exists(PROTOCOL_FILE):\n        return\n\n    last_mtime = os.path.getmtime(PROTOCOL_FILE)\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Monitoring {PROTOCOL_FILE} for changes...\")\n\n    while True:\n        try:\n            current_mtime = os.path.getmtime(PROTOCOL_FILE)\n            if current_mtime != last_mtime:\n                last_mtime = current_mtime\n                reload_protocol()\n            time.sleep(1)\n        except OSError:\n            pass\n        except Exception as e:\n            print(f\"Error monitoring protocol: {e}\")\n            time.sleep(5)\n\ndef start_monitor_thread():\n    \"\"\"Starts the monitor in a background thread.\"\"\"\n    monitor_thread = threading.Thread(target=monitor_protocol, daemon=True)\n    monitor_thread.start()\n\ndef is_running(pid):\n    \"\"\"Check if a process with the given PID is running.\"\"\"\n    try:\n        # Windows-specific check could be added here, but signal 0 is widely supported for existence check\n        # On Windows, os.kill with 0 is not supported in older versions, but usually fine in modern Python.\n        # Alternative: use tasklist\n        if os.name == 'nt':\n            # Use tasklist to check if PID exists\n            # Use errors='ignore' to handle potential non-UTF-8 output from localized Windows shell\n            output = subprocess.check_output(f'tasklist /FI \"PID eq {pid}\"', shell=True).decode(errors='ignore')\n            return str(pid) in output\n        else:\n            os.kill(pid, 0)\n            return True\n    except (OSError, subprocess.CalledProcessError):\n        return False\n\ndef start_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n\n    if fleet_mode:\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Fleet Mode: ACTIVE\")\n        for game in FLEET_GAMES:\n            pid_file = f\"src/bot_{game.lower()}.pid\"\n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            print(f\"Worker for {game} already running (PID: {pid}).\")\n                            continue\n                        else:\n                            print(f\"Found stale PID file for {game}. Cleaning up.\")\n                            os.remove(pid_file)\n                    except ValueError:\n                        print(f\"Invalid PID file for {game}. Cleaning up.\")\n                        os.remove(pid_file)\n\n            print(f\"Spawning worker for {game}...\")\n            spawn_worker(game, pid_file)\n    else:\n        # Legacy single mode\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                try:\n                    pid = int(f.read().strip())\n                    if is_running(pid):\n                        print(f\"Bot is already running (PID: {pid}).\")\n                        return\n                    else:\n                        print(\"Found stale PID file. Cleaning up.\")\n                except ValueError:\n                    print(\"Invalid PID file. Cleaning up.\")\n            \n            os.remove(PID_FILE)\n\n        print(\"Starting bot...\")\n        spawn_worker(None, PID_FILE)\n\ndef spawn_worker(game, pid_file):\n    args = [sys.executable, BOT_SCRIPT]\n    if game:\n        args.extend([\"--game\", game])\n    \n    # Detached execution\n    if os.name == 'nt':\n        # Windows: specific flags to detach\n        process = subprocess.Popen(\n            args,\n            creationflags=subprocess.CREATE_NEW_CONSOLE,\n            cwd=os.getcwd()\n        )\n    else:\n        # Unix\n        process = subprocess.Popen(\n            args,\n            stdout=subprocess.DEVNULL,\n            stderr=subprocess.DEVNULL,\n            stdin=subprocess.DEVNULL,\n            cwd=os.getcwd(),\n            start_new_session=True\n        )\n\n    with open(pid_file, 'w') as f:\n        f.write(str(process.pid))\n    \n    label = game if game else \"Main\"\n    print(f\"Worker '{label}' started with PID: {process.pid}\")\n\ndef stop_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    \n    pids_to_kill = []\n    \n    if fleet_mode:\n        for game in FLEET_GAMES:\n            pid_file = f\"src/bot_{game.lower()}.pid\"\n            if os.path.exists(pid_file):\n                pids_to_kill.append((game, pid_file))\n    \n    # Check main PID file too, just in case\n    if os.path.exists(PID_FILE):\n        pids_to_kill.append((\"Main\", PID_FILE))\n\n    if not pids_to_kill:\n        print(\"No active bots found.\")\n        return\n\n    for label, pid_file in pids_to_kill:\n        with open(pid_file, 'r') as f:\n            try:\n                pid = int(f.read().strip())\n            except ValueError:\n                print(f\"Invalid PID file for {label}.\")\n                os.remove(pid_file)\n                continue\n\n        if is_running(pid):\n            print(f\"Stopping {label} worker (PID: {pid})...\")\n            try:\n                if os.name == 'nt':\n                    subprocess.call(['taskkill', '/F', '/T', '/PID', str(pid)])\n                else:\n                    os.kill(pid, signal.SIGTERM)\n            except Exception as e:\n                print(f\"Error stopping {label}: {e}\")\n        else:\n            print(f\"{label} process not found. Cleaning up PID file.\")\n\n        if os.path.exists(pid_file):\n            os.remove(pid_file)\n    print(\"All bots stopped.\")\n\ndef status_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    active_workers = 0\n    \n    if fleet_mode:\n        print(f\"FLEET MODE: ENABLED\")\n        for game in FLEET_GAMES:\n            pid_file = f\"src/bot_{game.lower()}.pid\"\n            status = \"INACTIVE\"\n            pid_info = \"\"\n            \n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            status = \"ACTIVE\"\n                            pid_info = f\"(PID: {pid})\"\n                            active_workers += 1\n                        else:\n                            status = \"STALE\"\n                    except:\n                        status = \"ERROR\"\n            \n            print(f\"  - {game}: {status} {pid_info}\")\n    else:\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                content = f.read().strip()\n                try:\n                    pid = int(content)\n                    if is_running(pid):\n                        print(f\"STATUS: ACTIVE (PID: {pid})\")\n                        active_workers = 1\n                        return\n                    else:\n                        print(\"STATUS: INACTIVE (Stale PID file found)\")\n                except Exception as e:\n                    print(f\"STATUS: ERROR (Corrupted PID file): {e}\")\n        else:\n            print(\"STATUS: INACTIVE\")\n    \n    print(f\"TOTAL ACTIVE WORKERS: {active_workers}\")\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Bot Control Interface\")\n    parser.add_argument('command', choices=['/start_bot', '/stop_bot', '/status', '/monitor'], help=\"Command to execute\")\n    \n    if len(sys.argv) < 2:\n        parser.print_help()\n        sys.exit(1)\n\n    args = parser.parse_args()\n\n    if args.command == '/start_bot':\n        start_bot()\n    elif args.command == '/stop_bot':\n        stop_bot()\n    elif args.command == '/status':\n        status_bot()\n    elif args.command == '/monitor':\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Starting protocol monitor...\")\n        monitor_protocol()\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1771161587333}}
