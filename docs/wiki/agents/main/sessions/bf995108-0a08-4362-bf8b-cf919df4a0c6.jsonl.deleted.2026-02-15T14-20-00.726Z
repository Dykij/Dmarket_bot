{"type":"message","id":"d5ef8ae2","parentId":"d4c8ad71","timestamp":"2026-02-15T13:19:40.442Z","message":{"role":"toolResult","toolCallId":"read_1771161580418_94","toolName":"read","content":[{"type":"text","text":"import sys\n\nclass AgentWrapper:\n    def __init__(self, game_id):\n        self.game_id = game_id\n        self.supported_games = {\n            \"730\": \"CS2\",\n            \"252490\": \"Rust\",\n            \"440\": \"TF2\",\n            \"570\": \"Dota 2\"\n        }\n\n    def start(self):\n        if self.game_id not in self.supported_games:\n            print(f\"Error: Game ID {self.game_id} not supported.\")\n            return\n        \n        game_name = self.supported_games[self.game_id]\n        print(f\"Starting worker for {game_name} (ID: {self.game_id})...\")\n        # Logic to start the actual worker would go here\n\nif __name__ == \"__main__\":\n    # Default to CS2 if not specified\n    target_game_id = \"730\"\n    if len(sys.argv) > 1:\n        target_game_id = sys.argv[1]\n    \n    agent = AgentWrapper(target_game_id)\n    agent.start()\n"}],"isError":false,"timestamp":1771161580440}}
