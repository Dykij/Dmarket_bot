{"type":"message","id":"dcd56f45","parentId":"3fcd2cc1","timestamp":"2026-02-15T12:58:06.139Z","message":{"role":"toolResult","toolCallId":"read_1771160285992_7","toolName":"read","content":[{"type":"text","text":"import os\nimport asyncio\nfrom telegram import Bot, BotCommand, BotCommandScopeDefault\n\nasync def main():\n    token = os.getenv(\"TELEGRAM_BOT_TOKEN\")\n    if not token:\n        print(\"Error: TELEGRAM_BOT_TOKEN not set.\")\n        return\n\n    print(\"Initializing bot...\")\n    bot = Bot(token=token)\n    \n    commands = [\n        BotCommand(\"dm_start\", \"🚀 Start HFT Trading\"),\n        BotCommand(\"dm_stop\", \"🛑 STOP Trading\"),\n        BotCommand(\"dm_status\", \"📊 Fleet Status\"),\n        BotCommand(\"dm_dashboard\", \"📈 Dashboard\"),\n    ]\n    \n    print(\"Refreshing bot commands...\")\n    try:\n        await bot.set_my_commands(commands, scope=BotCommandScopeDefault())\n        print(\"Commands refreshed successfully.\")\n        \n        # Verify\n        current = await bot.get_my_commands()\n        print(\"Current commands:\")\n        for cmd in current:\n            print(f\" - /{cmd.command}: {cmd.description}\")\n            \n    except Exception as e:\n        print(f\"Error updating commands: {e}\")\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n"}],"isError":false,"timestamp":1771160286137}}
