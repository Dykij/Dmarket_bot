{"type":"message","id":"2720559f","parentId":"0d551cb7","timestamp":"2026-02-14T07:54:28.934Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write_1771055668924_93","name":"write","arguments":{"content":"import pytest\nimport time\nimport json\nfrom unittest.mock import AsyncMock, patch\nfrom src.api.dmarket import DMarketAPI\n\n@pytest.fixture\ndef api_keys():\n    return {\n        \"public\": \"1715cf6917e7595cc31b06c7637b4866e325d0e2280c39c1e1236b77af64f2b3\",\n        \"secret\": \"b11a916a20336ecb8687a5abc13562b6db137f6bac23af868f6e53422f5bd9461715cf6917e7595cc31b06c7637b4866e325d0e2280c39c1e1236b77af64f2b3\"\n    }\n\n@pytest.mark.asyncio\nasync def test_ed25519_signature_generation(api_keys):\n    \"\"\"Сценарий 1: Валидация Ed25519 подписи (Golden Path).\"\"\"\n    api = DMarketAPI(api_keys[\"public\"], api_keys[\"secret\"])\n    method = \"GET\"\n    path = \"/account/v1/balance\"\n    body = \"\"\n    \n    headers = api._generate_signature(method, path, body)\n    \n    assert headers[\"X-Api-Key\"] == api_keys[\"public\"]\n    assert \"X-Sign-Date\" in headers\n    assert headers[\"X-Request-Sign\"].startswith(\"dmar ed25519 \")\n    # Проверка длины сигнатуры (hex 64 байта = 128 символов)\n    signature = headers[\"X-Request-Sign\"].split(\" \")[2]\n    assert len(signature) == 128\n\n@pytest.mark.asyncio\nasync def test_api_429_backoff_simulation(api_keys):\n    \"\"\"Сценарий 2: Симуляция ошибки 429 (Too Many Requests).\"\"\"\n    api = DMarketAPI(api_keys[\"public\"], api_keys[\"secret\"])\n    \n    with patch(\"httpx.AsyncClient.request\", new_callable=AsyncMock) as mock_request:\n        # Сначала возвращаем 429, потом 200\n        mock_request.side_effect = [\n            AsyncMock(status_code=429, text=\"Too Many Requests\"),\n            AsyncMock(status_code=200, json=lambda: {\"usd\": \"1000\"})\n        ]\n        \n        # Переопределяем sleep, чтобы тест не ждал реально\n        with patch(\"asyncio.sleep\", new_callable=AsyncMock) as mock_sleep:\n            balance = await api.get_balance()\n            assert balance == 10.0\n            assert mock_request.call_count == 2\n            mock_sleep.assert_called()\n\n@pytest.mark.asyncio\nasync def test_api_500_session_resilience(api_keys):\n    \"\"\"Сценарий 3: Симуляция ошибки 500 (Server Error).\"\"\"\n    api = DMarketAPI(api_keys[\"public\"], api_keys[\"secret\"])\n    \n    with patch(\"httpx.AsyncClient.request\", new_callable=AsyncMock) as mock_request:\n        mock_request.return_value = AsyncMock(status_code=500, text=\"Internal Server Error\")\n        \n        # Проверяем, что бот возвращает пустой список объектов, а не падает\n        items = await api.get_market_items(\"csgo\")\n        assert items == {\"objects\": []}\n        assert mock_request.called\n","file_path":"tests/unit/test_dmarket_api_new.py"},"thoughtSignature":"EjQKMgG+Pvb70+NTSJDqM5rWh/7BPY3qYMUPQrwW7dBgvPouhapLLGsqBPpA3J86BYSYrXw+"},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-flash-preview","usage":{"input":139225,"output":936,"cacheRead":138600,"cacheWrite":0,"totalTokens":140161,"cost":{"input":0.0696125,"output":0.002808,"cacheRead":0.00693,"cacheWrite":0,"total":0.0793505}},"stopReason":"toolUse","timestamp":1771055664285}}
