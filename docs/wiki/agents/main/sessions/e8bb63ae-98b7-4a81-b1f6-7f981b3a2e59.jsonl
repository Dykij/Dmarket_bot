{"type":"message","id":"3abc58b4","parentId":"bcac2fa0","timestamp":"2026-02-14T07:43:36.864Z","message":{"role":"toolResult","toolCallId":"read_1771055016852_46","toolName":"read","content":[{"type":"text","text":"\"\"\"\nDMarket API Client (Clean Architecture Implementation).\nFollows Google Cloud Application Development guidelines for robustness and structure.\n\"\"\"\n\nimport asyncio\nimport hashlib\nimport hmac\nimport json\nimport logging\nimport time\nimport os\nfrom enum import Enum # Добавлен импорт Enum\nfrom typing import Any, Dict, List, Optional\nfrom urllib.parse import urlencode\nimport httpx\n\n# Dependencies\ntry:\n    import nacl.signing\n    from nacl.encoding import HexEncoder\n    HAS_NACL = True\nexcept ImportError:\n    HAS_NACL = False\n\n# Core Config (One-way dependency)\nfrom src.core.config import CONFIG\n\nlogger = logging.getLogger(\"api.dmarket\")\n\n# --- Начало кода Circuit Breaker ---\n\nclass CircuitBreakerState(Enum):\n    \"\"\"Состояния Circuit Breaker.\"\"\"\n    CLOSED = 1\n    OPEN = 2\n    HALF_OPEN = 3\n\nclass CircuitBreakerOpenException(Exception):\n    \"\"\"Исключение, выбрасываемое, когда Circuit Breaker находится в состоянии OPEN.\"\"\"\n    pass\n\nclass CircuitBreaker:\n    \"\"\"\n    Реализация Circuit Breaker для повышения отказоустойчивости API-вызовов.\n    \"\"\"\n    def __init__(self, failure_threshold: int = 5, recovery_timeout: int = 30, half_open_successes: int = 1):\n        \"\"\"\n        Инициализирует Circuit Breaker.\n\n        Args:\n            failure_threshold: Количество последовательных сбоев для переключения Circuit Breaker в состояние OPEN.\n            recovery_timeout: Время в секундах, после которого Circuit Breaker переходит из OPEN в HALF_OPEN.\n            half_open_successes: Количество успешных запросов в состоянии HALF_OPEN для закрытия Circuit Breaker.\n        \"\"\"\n        self.state = CircuitBreakerState.CLOSED\n        self.failure_threshold = failure_threshold\n        self.recovery_timeout = recovery_timeout\n        self.half_open_successes = half_open_successes\n\n        self.current_failures = 0\n        self.last_trip_time = 0.0\n        self.successful_requests_in_half_open = 0\n        self._lock: Optional[asyncio.Lock] = None # Инициализируем lock лениво\n        self._probationary_request_in_flight = False # Отслеживаем пробный запрос в HALF_OPEN\n\n    async def _get_lock(self) -> asyncio.Lock:\n        \"\"\"Ленивая инициализация asyncio.Lock.\"\"\"\n        if self._lock is None:\n            self._lock = asyncio.Lock()\n        return self._lock\n\n    async def __aenter__(self):\n        \"\"\"\n        Проверяет состояние Circuit Breaker перед выполнением запроса.\n        \"\"\"\n        lock = await self._get_lock()\n        async with lock:\n            if self.state == CircuitBreakerState.OPEN:\n                if time.time() - self.last_trip_time > self.recovery_timeout:\n                    logging.warning(\"Circuit Breaker переходит из OPEN в HALF_OPEN.\")\n                    self.state = CircuitBreakerState.HALF_OPEN\n                    self.successful_requests_in_half_open = 0\n                    self._probationary_request_in_flight = True # Разрешаем один пробный запрос\n                else:\n                    raise CircuitBreakerOpenException(\"Circuit Breaker открыт, запрос не будет выполнен.\")\n            elif self.state == CircuitBreakerState.HALF_OPEN:\n                if self._probationary_request_in_flight:\n                    # Если пробный запрос уже выполняется, остальные получают исключение\n                    raise CircuitBreakerOpenException(\"Circuit Breaker в HALF_OPEN, пробный запрос уже выполняется.\")\n                else:\n                    # Разрешаем один пробный запрос\n                    self._probationary_request_in_flight = True\n\n    async def __aexit__(self, exc_type, exc_val, exc_tb):\n        \"\"\"\n        Обновляет состояние Circuit Breaker после выполнения запроса.\n        \"\"\"\n        lock = await self._get_lock()\n        async with lock:\n            if self.state == CircuitBreakerState.HALF_OPEN:\n                self._probationary_request_in_flight = False # Пробный запрос завершен\n\n            if exc_type is None:  # Запрос был успешным\n                if self.state == CircuitBreakerState.HALF_OPEN:\n                    self.successful_requests_in_half_open += 1\n                    if self.successful_requests_in_half_open >= self.half_open_successes:\n                        logging.warning(\"Circuit Breaker переходит из HALF_OPEN в CLOSED.\")\n                        self.state = CircuitBreakerState.CLOSED\n                        self.current_failures = 0\n                        self.successful_requests_in_half_open = 0\n                elif self.state == CircuitBreakerState.CLOSED:\n                    self.current_failures = 0 # Сбрасываем счетчик сбоев при успехе\n            else:  # Запрос завершился с ошибкой\n                self.current_failures += 1\n                self.last_trip_time = time.time()\n                if self.state == CircuitBreakerState.HALF_OPEN:\n                    logging.warning(\"Circuit Breaker переходит из HALF_OPEN обратно в OPEN из-за сбоя.\")\n                    self.state = CircuitBreakerState.OPEN\n                elif self.state == CircuitBreakerState.CLOSED:\n                    if self.current_failures >= self.failure_threshold:\n                        logging.error(f\"Circuit Breaker переходит из CLOSED в OPEN после {self.current_failures} сбоев.\")\n                        self.state = CircuitBreakerState.OPEN\n\n# --- Конец кода Circuit Breaker ---\n\nclass DMarketAPI:\n    \"\"\"\n    Robust DMarket API Client.\n    Handles authentication, rate limiting, and multi-game switching.\n    \"\"\"\n\n    BASE_URL = \"https://api.dmarket.com\"\n\n    def __init__(self, public_key: str, secret_key: str, rate_limit: float = 0.2):\n        \"\"\"\n        Initialize the client.\n        \n        Args:\n            public_key: API Public Key\n            secret_key: API Secret Key\n            rate_limit: Minimum seconds between requests (basic throttling)\n        \"\"\"\n        self.public_key = public_key\n        self.secret_key = secret_key\n        self.rate_limit = rate_limit\n        self.last_request_time = 0.0\n        \n        # Initialize HTTP client with timeouts\n        self.client = httpx.AsyncClient(\n            timeout=30.0,\n            headers={\n                \"User-Agent\": \"OpenClaw-TradingBot/2.0\",\n                \"Accept\": \"application/json\"\n            }\n        )\n\n        # Инициализация Circuit Breaker\n        self.circuit_breaker = CircuitBreaker(\n            failure_threshold=5,     # Количество сбоев для открытия\n            recovery_timeout=30,     # Время в секундах для восстановления\n            half_open_successes=1    # Успешных запросов в HALF_OPEN для закрытия\n        )\n\n\n    def _generate_signature(self, method: str, path: str, body: str = \"\") -> Dict[str, str]:\n        \"\"\"\n        Generates DMarket API Signature (Ed25519 or HMAC-SHA256).\n        \"\"\"\n        timestamp = str(int(time.time()))\n        string_to_sign = f\"{method}{path}{body}{timestamp}\"\n        \n        headers = {\n            \"X-Api-Key\": self.public_key,\n            \"X-Sign-Date\": timestamp,\n            \"Content-Type\": \"application/json\"\n        }\n\n        # Try Ed25519 first (Preferred by DMarket)\n        if HAS_NACL and len(self.secret_key) == 128: # Hex representation of 64 bytes\n            try:\n                signing_key = nacl.signing.SigningKey(bytes.fromhex(self.secret_key))\n                signed = signing_key.sign(string_to_sign.encode('utf-8'))\n                signature = signed.signature.hex()\n                headers[\"X-Request-Sign\"] = f\"dmar ed25519 {signature}\"\n                return headers\n            except Exception as e:\n                logger.warning(f\"Ed25519 signing failed, falling back to HMAC: {e}\")\n\n        # Fallback to HMAC-SHA256\n        signature = hmac.new(\n            self.secret_key.encode('utf-8'),\n            string_to_sign.encode('utf-8'),\n            hashlib.sha256\n        ).hexdigest()\n        headers[\"X-Request-Sign\"] = signature\n        return headers\n\n    async def __aenter__(self):\n        return self\n\n    async def __aexit__(self, exc_type, exc_val, exc_tb):\n        await self.close()\n\n    async def _request(\n        self, \n        method: str, \n        endpoint: str, \n        params: Optional[Dict] = None, \n        data: Optional[Dict] = None,\n        retries: int = 3,\n        request_timeout: float = 30.0 # Добавлен отдельный таймаут для каждого запроса\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Выполнение запроса с логикой Circuit Breaker и повторных попыток.\n        \"\"\"\n        # Circuit Breaker: Проверяем, разрешен ли запрос\n        try:\n            async with self.circuit_breaker:\n                # Внутренний блок try/except для обработки конкретных ошибок запроса\n                for attempt in range(retries):\n                    try:\n                        # Rate Limiting\n                        elapsed = time.time() - self.last_request_time\n                        if elapsed < self.rate_limit:\n                            await asyncio.sleep(self.rate_limit - elapsed)\n                        \n                        url = f\"{self.BASE_URL}{endpoint}\"\n                        body_str = json.dumps(data) if data else \"\"\n                        \n                        path_for_sign = endpoint\n                        if params:\n                            sorted_params = sorted(params.items())\n                            query_string = urlencode(sorted_params)\n                            path_for_sign = f\"{endpoint}?{query_string}\"\n\n                        headers = self._generate_signature(method, path_for_sign, body_str)\n                        \n                        response = await self.client.request(\n                            method, \n                            url, \n                            params=params, \n                            content=body_str, \n                            headers=headers,\n                            timeout=request_timeout # Применяем таймаут к конкретному запросу\n                        )\n                        \n                        self.last_request_time = time.time()\n\n                        if response.status_code == 200:\n                            return response.json()\n                        elif response.status_code == 429:\n                            logger.warning(f\"Rate limit hit. Sleeping... (Attempt {attempt+1}/{retries})\")\n                            await asyncio.sleep(2 ** attempt) # Экспоненциальная задержка\n                        else:\n                            logger.error(f\"API Error {response.status_code}: {response.text}\")\n                            if 400 <= response.status_code < 500 and response.status_code != 429:\n                                # Для клиентских ошибок, не связанных с лимитом, не повторяем\n                                return {\"objects\": []} \n                    \n                    except httpx.RequestError as e:\n                        logging.error(f\"Network error during request (Attempt {attempt+1}/{retries}): {e}\")\n                        await asyncio.sleep(1) # Короткая задержка при сетевых ошибках\n\n                # Если все попытки исчерпаны и Circuit Breaker не открылся, возвращаем пустой результат\n                logging.error(f\"All {retries} attempts failed for {method} {endpoint}. Returning empty result.\")\n                return {\"objects\": []}\n\n        except CircuitBreakerOpenException as cboe:\n            logging.warning(f\"Request short-circuited by Circuit Breaker: {cboe}\")\n            return {\"objects\": []}\n        except Exception as e:\n            logging.critical(f\"An unhandled exception occurred in _request: {e}\", exc_info=True)\n            return {\"objects\": []}\n\n    async def get_market_items(\n        self,\n        game: str,\n        limit: int = 50,\n        price_from: float = 0.0,\n        price_to: float = 0.0,\n        currency: str = \"USD\",\n        sort: str = \"price\"\n    ) -> Dict[str, Any]:\n        \"\"\"\n        Fetch items for a specific game using GAME_CONFIG.\n        Endpoint: /exchange/v1/market/items (Standard Exchange API)\n        \"\"\"\n        game_config = CONFIG.GAMES.get(game)\n        if not game_config:\n            logger.error(f\"Game '{game}' not found in CONFIG.\")\n            return {\"objects\": []}\n\n        params = {\n            \"gameId\": game_config.dmarket_id,\n            \"limit\": limit,\n            \"currency\": currency,\n            \"orderBy\": sort,\n            \"priceFrom\": int(price_from * 100), # Convert to cents\n            \"priceTo\": int(price_to * 100)\n        }\n        \n        return await self._request(\"GET\", \"/exchange/v1/market/items\", params=params)\n\n    async def get_balance(self) -> float:\n        \"\"\"\n        Get current USD balance.\n        Endpoint: /account/v1/balance\n        Returns: Balance in USD (float)\n        \"\"\"\n        data = await self._request(\"GET\", \"/account/v1/balance\")\n        # Response format: {\"usd\": 4550, \"dmc\": ...} (in cents)\n        cents = int(data.get(\"usd\", 0))\n        return float(cents) / 100.0\n\n    async def get_offers_by_title(self, title: str, game: str = \"csgo\", limit: int = 10) -> Dict[str, Any]:\n        \"\"\"\n        Get specific offers for a title.\n        Endpoint: /exchange/v1/offers-by-title (Strictly from JSON)\n        \"\"\"\n        game_config = CONFIG.GAMES.get(game)\n        if not game_config: return {}\n\n        params = {\n            \"Title\": title,\n            \"GameID\": game_config.dmarket_id,\n            \"Limit\": limit,\n            \"Currency\": \"USD\"\n        }\n        return await self._request(\"GET\", \"/exchange/v1/offers-by-title\", params=params)\n\n    async def buy_item(self, item_id: str, price: int, game: str = \"csgo\") -> Dict[str, Any]:\n        \"\"\"\n        Execute Buy Order.\n        Endpoint: /exchange/v1/offers/buy\n        Payload: Price in coins (cents).\n        \"\"\"\n        payload = {\n            \"offers\": [\n                {\n                    \"offerId\": item_id,\n                    \"price\": {\"amount\": str(price), \"currency\": \"USD\"},\n                    \"type\": \"dmarket\"\n                }\n            ]\n        }\n        # Dry Run for now\n        logger.info(f\"DRY RUN BUY: {item_id} for {price} cents\")\n        return {\"status\": \"dry_run_success\"}\n\n    async def close(self):\n        await self.client.aclose()\n\n# --- Consilium Test Runner ---\nif __name__ == \"__main__\":\n    from dotenv import load_dotenv\n    load_dotenv()\n    \n    # Configure Logging\n    logging.basicConfig(\n        level=logging.INFO,\n        format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n    )\n\n    async def test_multigame():\n        pub = os.getenv(\"DMARKET_PUBLIC_KEY\")\n        sec = os.getenv(\"DMARKET_SECRET_KEY\")\n        \n        if not pub or not sec:\n            print(\"❌ Keys missing.\")\n            return\n\n        api = DMarketAPI(pub, sec)\n        print(\"🤖 DMarketAPI Initialized. Starting Multigame Test...\\n\")\n\n        games = [\"csgo\", \"dota2\", \"rust\", \"tf2\"]\n        \n        for game in games:\n            print(f\"📡 Requesting {game.upper()}...\")\n            data = await api.get_market_items(game, limit=5, price_from=1.0, price_to=10.0)\n            items = data.get(\"objects\", [])\n            \n            if items:\n                first = items[0]\n                price = float(first['price']['USD']) / 100\n                print(f\"✅ {game.upper()}: Success! Found {len(items)} items.\")\n                print(f\"   Sample: {first['title']} (${price})\")\n            else:\n                print(f\"⚠️ {game.upper()}: No items returned (or error).\")\n            \n            print(\"-\" * 30)\n        \n        await api.close()\n\n    asyncio.run(test_multigame())"}],"isError":false,"timestamp":1771055016862}}
