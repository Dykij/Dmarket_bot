{"type":"message","id":"5da8802c","parentId":"51b84669","timestamp":"2026-02-14T07:47:13.178Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write_1771055233170_51","name":"write","arguments":{"content":"import hmac\nimport hashlib\nimport time\nimport httpx\nimport asyncio\n\nPUBLIC_KEY = \"1715cf6917e7595cc31b06c7637b4866e325d0e2280c39c1e1236b77af64f2b3\"\nSECRET_KEY = \"b11a916a20336ecb8687a5abc13562b6db137f6bac23af868f6e53422f5bd9461715cf6917e7595cc31b06c7637b4866e325d0e2280c39c1e1236b77af64f2b3\"\n\nasync def check_variant(name, secret_bytes):\n    method = \"GET\"\n    path = \"/account/v1/balance\"\n    timestamp = str(int(time.time()))\n    body = \"\"\n    string_to_sign = f\"{method}{path}{body}{timestamp}\"\n    \n    signature = hmac.new(\n        secret_bytes,\n        string_to_sign.encode('utf-8'),\n        hashlib.sha256\n    ).hexdigest()\n    \n    headers = {\n        \"X-Api-Key\": PUBLIC_KEY,\n        \"X-Sign-Date\": timestamp,\n        \"X-Request-Sign\": signature,\n        \"Content-Type\": \"application/json\"\n    }\n    \n    async with httpx.AsyncClient() as client:\n        r = await client.get(f\"https://api.dmarket.com{path}\", headers=headers)\n        print(f\"Variant: {name} | Status: {r.status_code} | Body: {r.text[:100]}\")\n\nasync def main():\n    # Вариант 1: Секрет как строка (UTF-8)\n    await check_variant(\"Plain String\", SECRET_KEY.encode('utf-8'))\n    \n    # Вариант 2: Секрет как HEX (Декодированный)\n    try:\n        hex_bytes = bytes.fromhex(SECRET_KEY)\n        await check_variant(\"Hex Decoded\", hex_bytes)\n    except:\n        print(\"Hex Decoded: Invalid HEX\")\n\nif __name__ == \"__main__\":\n    asyncio.run(main())\n","file_path":"debug_auth_variants.py"},"thoughtSignature":"EjQKMgG+Pvb7xwjT45FM4oeJzqwpW0n+N9pFmD9l0LlvxsynpW/scIoU7f/aDfrbWp2eYvSP"},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-flash-preview","usage":{"input":50320,"output":6