{"type":"message","id":"876e3081","parentId":"42234ffe","timestamp":"2026-02-14T07:38:16.548Z","message":{"role":"toolResult","toolCallId":"read_1771054696539_30","toolName":"read","content":[{"type":"text","text":"import asyncio\nimport logging\nimport os\nimport random\nimport sys\nfrom typing import NoReturn\n\n# Внутренние модули\nfrom src.api.dmarket import DMarketAPI\nfrom src.core.config import CONFIG\nfrom src.utils.resilience import CircuitBreaker, get_jitter\n\n# Настройка логирования в файл\nos.makedirs(\"logs\", exist_ok=True)\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s [%(levelname)s] %(name)s: %(message)s',\n    handlers=[\n        logging.StreamHandler(sys.stdout),\n        logging.FileHandler(\"logs/error.log\", encoding=\"utf-8\")\n    ]\n)\nlogger = logging.getLogger(\"bot.main\")\n\nasync def main_loop() -> NoReturn:\n    \"\"\"\n    Главный цикл управления ботом (Бессмертный цикл).\n    \"\"\"\n    logger.info(\"Запуск главного цикла DMarket Bot [DRP-2026]\")\n    \n    # Инициализируем предохранитель для DMarket\n    dmarket_breaker = CircuitBreaker(failure_threshold=5, recovery_timeout=60, name=\"DMarket-API\")\n\n    while True:\n        try:\n            # Используем контекстный менеджер для управления сессией (Anti-Leak)\n            # Примечание: В текущей версии DMarketAPI должен поддерживать __aenter__ и __aexit__\n            async with DMarketAPI(\n                public_key=CONFIG.API.PUBLIC_KEY,\n                secret_key=CONFIG.API.SECRET_KEY\n            ) as api:\n                \n                logger.info(\"Сессия API установлена. Начинаю сканирование...\")\n                \n                while True:\n                    if not dmarket_breaker.can_execute():\n                        logger.warning(\"Пауза: Circuit Breaker активен. Ждем восстановления API...\")\n                        await asyncio.sleep(10)\n                        continue\n\n                    try:\n                        # Пример основной логики: получение баланса\n                        balance = await api.get_balance()\n                        dmarket_breaker.record_success()\n                        \n                        # logger.info(f\"Текущий баланс: {balance} USD\")\n                        \n                        # Интервал сканирования из конфига с джиттером\n                        scan_interval = getattr(CONFIG.BOT, 'SCAN_INTERVAL', 30.0)\n                        await asyncio.sleep(get_jitter(scan_interval))\n\n                    except Exception as api_err:\n                        dmarket_breaker.record_failure()\n                        logger.error(f\"Ошибка API DMarket: {api_err}\")\n                        # Если сетевая ошибка, выходим для реинициализации клиента\n                        if \"Network error\" in str(api_err) or \"httpx\" in str(api_err).lower():\n                            break \n                        await asyncio.sleep(get_jitter(5.0))\n\n        except Exception as fatal_err:\n            logger.critical(f\"Критический сбой цикла: {fatal_err}. Перезапуск через 15 секунд...\")\n            await asyncio.sleep(15)\n            continue\n\nif __name__ == \"__main__\":\n    try:\n        asyncio.run(main_loop())\n    except KeyboardInterrupt:\n        logger.info(\"Бот остановлен пользователем.\")\n    except Exception as e:\n        logger.error(f\"Бот упал с ошибкой: {e}\")\n"}],"isError":false,"timestamp":1771054696546}}
