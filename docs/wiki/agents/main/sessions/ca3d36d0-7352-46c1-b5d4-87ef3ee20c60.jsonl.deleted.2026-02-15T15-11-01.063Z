abled: true\r\n  max_same_items_in_inventory: 5\r\n  max_single_item_percent: 25\r\n  min_different_items: 5\r\n  max_stack_value_percent: 15\r\n\r\ngame_strategy:\r\n  enabled: true\r\n  weights:\r\n    tf2: 30\r\n    csgo: 40\r\n    rust: 20\r\n    dota2: 10\r\n\r\nwhitelist:\r\n  enabled: true\r\n  file_path: \"data/whitelist.json\"\r\n  priority_only: false\r\n  buy_max_overpay_percent: 2.0\r\n\r\nauto_sell:\r\n  enabled: true\r\n  min_margin_percent: 4.0\r\n  max_margin_percent: 12.0\r\n  target_margin_percent: 8.0\r\n  undercut_cents: 1\r\n  price_check_interval_minutes: 30\r\n  stop_loss_hours: 48\r\n  stop_loss_percent: 5.0\r\n  max_active_sales: 50\r\n  delay_before_list_seconds: 5\r\n  pricing_strategy: \"undercut\"\r\n  dmarket_fee_percent: 7.0\r\n\r\nrepricing:\r\n  enabled: true\r\n  intervals:\r\n    - hours: 24\r\n      action: \"reduce_to_target\"\r\n    - hours: 48\r\n      action: \"reduce_to_break_even\"\r\n    - hours: 72\r\n      action: \"liquidate\"\r\n  max_price_cut_percent: 15\r\n  night_mode:\r\n    enabled: true\r\n    start_hour: 2\r\n    end_hour: 6\r\n    undercut_multiplier: 2.0\r\n\r\npanic_protection:\r\n  enabled: true\r\n  threshold_percent: 15\r\n  check_window_hours: 1\r\n  action: \"pause\"\r\n\r\nblacklist:\r\n  enabled: true\r\n  file_path: \"data/blacklist.json\"\r\n  auto_blacklist_threshold: 3\r\n  failure_expiry_hours: 24\r\n  forbidden_keywords:\r\n    - \"Souvenir\"\r\n    - \"Well-Worn\"\r\n    - \"Inscribed Gem\"\r\n    - \"StatTrak™ Music Kit\"\r\n    - \"Autograph\"\r\n\r\nmarket_sentiment:\r\n  enabled: true\r\n  check_interval_minutes: 15\r\n  panic_sell_threshold: -0.07\r\n  high_risk_hunt: true\r\n  speculative_budget_pct: 0.15\r\n\r\nsteam_parser:\r\n  enabled: true\r\n  cache_ttl: 300\r\n  max_concurrent_requests: 10\r\n  request_timeout: 5.0\r\n  use_proxy: false\r\n  proxy_url: \"\"\r\n  requests_per_minute: 30\r\n  arbitrage:\r\n    min_profit_percent: 15\r\n    max_discount_percent: 50\r\n\r\nintelligent_h