{"type":"message","id":"61c3fa02","parentId":"e3caa6e3","timestamp":"2026-02-18T19:06:20.398Z","message":{"role":"toolResult","toolCallId":"read_1771441580248_26","toolName":"read","content":[{"type":"text","text":"import os\nimport glob\n\n\ndef compress_logs():\n    \"\"\"Reads all log files, deduplicates lines, and compresses output.\"\"\"\n    log_files = glob.glob('logs/*.log')\n    all_lines = []\n\n    for log_file in log_files:\n        try:\n            with open(log_file, 'r', encoding='utf-8') as f:\n                all_lines.extend(f.readlines())\n        except Exception as e:\n            print(f\"Error reading {log_file}: {e}\")\n            continue\n\n    # Deduplicate lines while preserving order\n    seen = set()\n    unique_lines = []\n    for line in all_lines:\n        if line not in seen:\n            unique_lines.append(line)\n            seen.add(line)\n\n    # Join lines\n    content = \"\".join(unique_lines)\n\n    # Limit to last 50,000 characters\n    limit = 50000\n    if len(content) > limit:\n        content = content[-limit:]\n        # Try to cut at a newline to be cleaner\n        first_newline = content.find('\\n')\n        if first_newline != -1:\n            content = content[first_newline + 1:]\n\n    output_path = 'logs/compressed_context.md'\n    try:\n        with open(output_path, 'w', encoding='utf-8') as f:\n            f.write(\"# Compressed Log Context\\n\\n\")\n            f.write(content)\n        print(f\"Successfully compressed logs to {output_path}\")\n    except Exception as e:\n        print(f\"Error writing to {output_path}: {e}\")\n\n\nif __name__ == \"__main__\":\n    compress_logs()\n"}],"isError":false,"timestamp":1771441580397}}
{"type":"message","id":"cda002c9","parentId":"61c3fa02","timestamp":"2026-02-18T19:06:20.403Z","message":{"role":"toolResult","toolCallId":"read_1771441580368_27","toolName":"read","content":[{"type":"text","text":"import sys\nimport time\nimport random\nimport os\n\ndef start_bot_cs2():\n    print(\"Starting CS2 Bot (AppID 730)...\")\n    print(\"Config: DRY_RUN=True, http2=True\")\n    print(\"Strategy: Inventory Lag Exploit\")\n\n    log_file = \"logs/bot_cs2.log\"\n    os.makedirs(\"logs\", exist_ok=True)\n\n    # Simulate bot activity\n    with open(log_file, \"w\") as f:\n        f.write(\"[INFO] Bot started. Target: CS2 Worker (730)\\n\")\n        f.write(\"[INFO] Strategy: Inventory Lag Exploit initialized.\\n\")\n\n        # Simulate initial run\n        for i in range(10):\n            time.sleep(0.1)\n            f.write(f\"[INFO] Scanning inventory... Item {i+1}/100\\n\")\n\n        # Simulate some HTTP/2 jitter or Auth errors occasionally\n        if random.random() < 0.3:\n            f.write(\"[WARN] HTTP/2 stream reset. Retrying...\\n\")\n\n        # Simulate 401/403 errors (Watchdog trigger)\n        if random.random() < 0.5:\n             f.write(\"[ERROR] 401 Unauthorized. Check API key permissions.\\n\")\n\n        f.write(\"[INFO] Inventory scan complete.\\n\")\n\nif __name__ == \"__main__\":\n    if len(sys.argv) > 1 and sys.argv[1] == \"/start_bot_cs2\":\n        start_bot_cs2()\n    else:\n        print(\"Usage: python src/agent_wrapper.py /start_bot_cs2\")\n"}],"isError":false,"timestamp":1771441580402}}
