{"type":"message","id":"58e370d7","parentId":"e70d68f3","timestamp":"2026-02-13T17:53:40.678Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write_1771005220675_152","name":"write","arguments":{"content":"import asyncio\nimport os\nimport sys\nimport json\n\n# Add the bot directory to path\nBOT_DIR = r\"D:\\DMarket-Telegram-Bot-main\"\nsys.path.append(BOT_DIR)\n\nfrom dotenv import load_dotenv\nload_dotenv(os.path.join(BOT_DIR, \".env\"))\n\n# Mock CONFIG since we don't want to load the whole thing if it's complex\n# But we need to see what src.core.config expects.\n# For now, let's try to import it and see if it works.\ntry:\n    from src.api.dmarket import DMarketAPI\n    from src.core.config import CONFIG\nexcept ImportError as e:\n    print(f\"Import error: {e}\")\n    sys.exit(1)\n\nasync def sync_inventory():\n    pub = os.getenv(\"DMARKET_PUBLIC_KEY\")\n    sec = os.getenv(\"DMARKET_SECRET_KEY\")\n    \n    if not pub or not sec or \"your_\" in pub:\n        print(\"Error: API keys not configured in .env\")\n        return\n\n    async with DMarketAPI(pub, sec) as api:\n        # Get balance first as a health check\n        balance = await api.get_balance()\n        print(f\"Current Balance: ${balance}\")\n        \n        # Get user items (Inventory)\n        # The API client has get_market_items but maybe not get_user_items exposed cleanly?\n        # Let's check the dmarket.py again for getUserItems\n        # Looking at the code I read earlier, it had get_balance, get_market_items...\n        # I need to see if it has get_user_items.\n        \n        # Let's check the available methods on api\n        methods = [m for m in dir(api) if not m.startswith(\"__\")]\n        print(f\"Available methods: {methods}\")\n        \n        # If get_user_items doesn't exist, we use the raw _request\n        # Based on the swagger: /exchange/v1/user/items\n        inventory = await api._request(\"GET\", \"/exchange/v1/user/items\", params={\"gameId\": \"a8db\"}) # CS\n        \n        # Also check DMarket stored items: /marketplace-api/v1/user-inventory\n        dm_inventory = await api._request(\"GET\", \"/marketplace-api/v1/user-inventory\", params={\"GameID\": \"a8db\"})\n        \n        result = {\n            \"balance\": balance,\n            \"steam_inventory_count\": len(inventory.get(\"objects\", [])),\n            \"dmarket_inventory_count\": len(dm_inventory.get(\"objects\", [])),\n            \"sample_items\": (inventory.get(\"objects\", []) + dm_inventory.get(\"objects\", []))[:5]\n        }\n        print(json.dumps(result, indent=2))\n\nif __name__ == \"__main__\":\n    asyncio.run(sync_inventory())\n","file_path":"sync_inventory.py"},"thoughtSignature":"EjQKMgG+Pvb7VM7T9mLF3pTUYZAqP5v5Fo7AV5n9KSltLWQRhKhkg7sTyJ4mz3xHfcfBfA27"},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-flash-preview","usage":{"input":36379,"output":711,"cacheRead":32523,"cacheWrite":0,"totalTokens":37090,"cost":{"input":0.0181895,"output":0.002133,"cacheRead":0.00162615,"cacheWrite":0,"total":0.02194865}},"stopReason":"toolUse","timestamp":1771005215104}}
