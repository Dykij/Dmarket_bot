{"type":"message","id":"45381b35","parentId":"cce84f38","timestamp":"2026-02-13T17:53:17.467Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write_1771005197464_134","name":"write","arguments":{"content":"import sqlite3\nimport json\nimport os\n\nDB_PATH = r\"D:\\DMarket-Telegram-Bot-main\\data\\bot_database.db\"\n\ndef get_inventory():\n    if not os.path.exists(DB_PATH):\n        return {\"error\": \"Database not found\"}\n    \n    try:\n        conn = sqlite3.connect(DB_PATH)\n        cursor = conn.cursor()\n        \n        # Try to find inventory or items table\n        cursor.execute(\"SELECT name FROM sqlite_master WHERE type='table';\")\n        tables = [row[0] for row in cursor.fetchall()]\n        \n        inventory_data = {\"tables\": tables, \"items\": []}\n        \n        # Common table names in this kind of bot\n        target_table = None\n        for t in [\"inventory\", \"items\", \"user_items\", \"assets\"]:\n            if t in tables:\n                target_table = t\n                break\n        \n        if target_table:\n            cursor.execute(f\"SELECT * FROM {target_table} LIMIT 50\")\n            columns = [description[0] for description in cursor.description]\n            rows = cursor.fetchall()\n            for row in rows:\n                inventory_data[\"items\"].append(dict(zip(columns, row)))\n        \n        conn.close()\n        return inventory_data\n    except Exception as e:\n        return {\"error\": str(e)}\n\nif __name__ == \"__main__\":\n    print(json.dumps(get_inventory(), indent=2))\n","file_path":"check_db.py"},"thoughtSignature":"EjQKMgG+Pvb71DA+W+RgNy4ESGZL9QqDq2IuOHXbnBcJKKGSGJ+Lw9H8Vq+1c9wpPmFIOCIh"},{"type":"text","text":""}],"api":"google-generative-ai","provider":"google","model":"gemini-3-flash-preview","usage":{"input":35834,"output":374,"cacheRead":32537,"cacheWrite":0,"totalTokens":36208,"cost":{"input":0.017917,"output":0.001122,"cacheRead":0.0016268500000000002,"cacheWrite":0,"total":0.02066585}},"stopReason":"toolUse","timestamp":1771005194446}}
