{"type":"message","id":"96e8dd0f","parentId":"2db28aeb","timestamp":"2026-02-15T14:40:11.577Z","message":{"role":"toolResult","toolCallId":"read_1771166411560_297","toolName":"read","content":[{"type":"text","text":"services:\n  redis:\n    image: redis:alpine\n    container_name: dmarket_redis\n    restart: always\n    command: redis-server --save 60 1 --loglevel warning\n    sysctls:\n      net.core.somaxconn: 1024\n    healthcheck:\n      test: [\"CMD\", \"redis-cli\", \"ping\"]\n      interval: 5s\n      timeout: 3s\n      retries: 5\n    networks:\n      - bot_net\n\n  master:\n    build: .\n    container_name: bot_master\n    restart: unless-stopped\n    command: python -m src.master\n    env_file:\n      - .env\n    volumes:\n      - D:\\Dmarket_bot\\logs:/app/logs\n    healthcheck:\n      test: [\"CMD\", \"curl\", \"-f\", \"http://localhost:8501/_stcore/health\"]\n      interval: 30s\n      timeout: 10s\n      retries: 3\n    depends_on:\n      redis:\n        condition: service_healthy\n    networks:\n      - bot_net\n    sysctls:\n      net.ipv4.tcp_keepalive_time: 60\n\n  worker-cs2:\n    build: .\n    restart: unless-stopped\n    command: python -m src.worker --type cs2\n    deploy:\n      replicas: 2\n    env_file:\n      - .env\n    volumes:\n      - D:\\Dmarket_bot\\logs:/app/logs\n    depends_on:\n      - master\n      - redis\n    networks:\n      - bot_net\n\n  worker-rust:\n    build: .\n    restart: unless-stopped\n    command: python -m src.worker --type rust\n    deploy:\n      replicas: 2\n    env_file:\n      - .env\n    volumes:\n      - D:\\Dmarket_bot\\logs:/app/logs\n    depends_on:\n      - master\n      - redis\n    networks:\n      - bot_net\n\nnetworks:\n  bot_net:\n    driver: bridge\n    driver_opts:\n      com.docker.network.bridge.enable_icc: \"true\"\n"}],"isError":false,"timestamp":1771166411575}}
