ture":""}],"api":"google-vertex","provider":"google-vertex","model":"gemini-3-pro-preview","usage":{"input":82664,"output":959,"cacheRead":79610,"cacheWrite":0,"totalTokens":83623,"cost":{"input":0.165328,"output":0.011508000000000001,"cacheRead":0.015922000000000002,"cacheWrite":0,"total":0.19275799999999998}},"stopReason":"toolUse","timestamp":1771166552773}}
