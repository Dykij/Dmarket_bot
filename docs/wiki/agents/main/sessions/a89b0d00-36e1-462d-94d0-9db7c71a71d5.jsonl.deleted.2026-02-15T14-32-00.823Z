{"type":"message","id":"bee06438","parentId":"c857a884","timestamp":"2026-02-15T13:32:29.982Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"**Refining Implementation Steps**\n\nI'm currently working on modifying the `src/agent_wrapper.py` file. The goal is to update `FLEET_GAMES` to iterate through the specified AppIDs, namely [730, 570, 440, 252490]. Additionally, I intend to adjust `spawn_worker` to set `os.environ[\"TARGET_APP_ID\"]`. Finally, I will be updating the PID file naming convention to use \"bot_<appid>.pid.\"\n\n\n**Executing Code Modifications**\n\nNow, I'm working through the code. I'm focusing on incorporating the `FLEET_APPS` iteration and setting the `TARGET_APP_ID` environment variable within `spawn_worker` in `src/agent_wrapper.py`. I've already confirmed the AppIDs and the PID file naming. I am now finalizing the implementation details, making sure to avoid any potential regressions.\n\n\n**Updating Agent Wrapper Logic**\n\nI'm now rewriting `src/agent_wrapper.py`. I've assessed that a complete rewrite is cleanest given the scope of changes, including the `FLEET_APPS` iteration and `TARGET_APP_ID` environment variable setup within `spawn_worker`. Additionally, I'm accounting for necessary updates to `stop_bot` and `status_bot` to accommodate the new PID naming scheme and fleet operation.\n\n\n"},{"type":"toolCall","id":"write_1771162349866_141","name":"write","arguments":{"content":"import sys\nimport os\nimport subprocess\nimport argparse\nimport signal\nimport time\nimport threading\nimport json\n\nPID_FILE = \"src/bot.pid\"\nBOT_SCRIPT = \"src/trading_bot.py\"\nPROTOCOL_FILE = \"docs_archive/MASTER_PROTOCOL.md\"\nCONFIG_FILE = \"openclaw.json\"\n\n# AppIDs: CS2, Dota2, TF2, Rust\nFLEET_APPS = [\"730\", \"570\", \"440\", \"252490\"]\n\ndef load_config():\n    \"\"\"Load config from openclaw.json.\"\"\"\n    if os.path.exists(CONFIG_FILE):\n        try:\n            with open(CONFIG_FILE, 'r') as f:\n                return json.load(f)\n        except Exception as e:\n            print(f\"Error loading config: {e}\")\n    return {}\n\ndef reload_protocol():\n    \"\"\"Reloads the master protocol configuration.\"\"\"\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Hot Reload: Active\")\n\ndef monitor_protocol():\n    \"\"\"Monitors the protocol file for changes.\"\"\"\n    config = load_config()\n    sys_caps = config.get(\"system_capabilities\", {})\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Integrity: fleet_mode={config.get('fleet_mode')}, lazy_loading={sys_caps.get('lazy_loading')}, Ed25519={sys_caps.get('Ed25519')}\")\n\n    if not os.path.exists(PROTOCOL_FILE):\n        return\n\n    last_mtime = os.path.getmtime(PROTOCOL_FILE)\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Monitoring {PROTOCOL_FILE} for changes...\")\n\n    while True:\n        try:\n            current_mtime = os.path.getmtime(PROTOCOL_FILE)\n            if current_mtime != last_mtime:\n                last_mtime = current_mtime\n                reload_protocol()\n            time.sleep(1)\n        except OSError:\n            pass\n        except Exception as e:\n            print(f\"Error monitoring protocol: {e}\")\n            time.sleep(5)\n\ndef is_running(pid):\n    \"\"\"Check if a process with the given PID is running.\"\"\"\n    try:\n        if os.name == 'nt':\n            output = subprocess.check_output(f'tasklist /FI \"PID eq {pid}\"', shell=True).decode(errors='ignore')\n            return str(pid) in output\n        else:\n            os.kill(pid, 0)\n            return True\n    except (OSError, subprocess.CalledProcessError):\n        return False\n\ndef start_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n\n    if fleet_mode:\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Fleet Mode: ACTIVE\")\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            print(f\"Worker for AppID {app_id} already running (PID: {pid}).\")\n                            continue\n                        else:\n                            print(f\"Found stale PID file for {app_id}. Cleaning up.\")\n                            os.remove(pid_file)\n                    except ValueError:\n                        print(f\"Invalid PID file for {app_id}. Cleaning up.\")\n                        os.remove(pid_file)\n\n            print(f\"Spawning worker for AppID {app_id}...\")\n            spawn_worker(app_id, pid_file)\n    else:\n        # Legacy single mode (defaulting to CS2/730 if not specified)\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                try:\n                    pid = int(f.read().strip())\n                    if is_running(pid):\n                        print(f\"Bot is already running (PID: {pid}).\")\n                        return\n                    else:\n                        print(\"Found stale PID file. Cleaning up.\")\n                except ValueError:\n                    print(\"Invalid PID file. Cleaning up.\")\n            \n            os.remove(PID_FILE)\n\n        print(\"Starting single bot instance...\")\n        spawn_worker(\"730\", PID_FILE)\n\ndef spawn_worker(app_id, pid_file):\n    args = [sys.executable, BOT_SCRIPT]\n    \n    env = os.environ.copy()\n    if app_id:\n        env[\"TARGET_APP_ID\"] = app_id\n\n    # Detached execution\n    if os.name == 'nt':\n        process = subprocess.Popen(\n            args,\n            creationflags=subprocess.CREATE_NEW_CONSOLE,\n            cwd=os.getcwd(),\n            env=env\n        )\n    else:\n        process = subprocess.Popen(\n            args,\n            stdout=subprocess.DEVNULL,\n            stderr=subprocess.DEVNULL,\n            stdin=subprocess.DEVNULL,\n            cwd=os.getcwd(),\n            start_new_session=True,\n            env=env\n        )\n\n    with open(pid_file, 'w') as f:\n        f.write(str(process.pid))\n    \n    print(f\"Worker for AppID {app_id} started with PID: {process.pid}\")\n\ndef stop_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    \n    pids_to_kill = []\n    \n    if fleet_mode:\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            if os.path.exists(pid_file):\n                pids_to_kill.append((f\"AppID {app_id}\", pid_file))\n    \n    # Check main PID file too\n    if os.path.exists(PID_FILE):\n        pids_to_kill.append((\"Main\", PID_FILE))\n\n    if not pids_to_kill:\n        print(\"No active bots found.\")\n        return\n\n    for label, pid_file in pids_to_kill:\n        with open(pid_file, 'r') as f:\n            try:\n                pid = int(f.read().strip())\n            except ValueError:\n                print(f\"Invalid PID file for {label}.\")\n                os.remove(pid_file)\n                continue\n\n        if is_running(pid):\n            print(f\"Stopping {label} worker (PID: {pid})...\")\n            try:\n                if os.name == 'nt':\n                    subprocess.call(['taskkill', '/F', '/T', '/PID', str(pid)])\n                else:\n                    os.kill(pid, signal.SIGTERM)\n            except Exception as e:\n                print(f\"Error stopping {label}: {e}\")\n        else:\n            print(f\"{label} process not found. Cleaning up PID file.\")\n\n        if os.path.exists(pid_file):\n            os.remove(pid_file)\n    print(\"All bots stopped.\")\n\ndef status_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    active_workers = 0\n    \n    if fleet_mode:\n        print(f\"FLEET MODE: ENABLED\")\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            status = \"INACTIVE\"\n            pid_info = \"\"\n            \n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            status = \"ACTIVE\"\n                            pid_info = f\"(PID: {pid})\"\n                            active_workers += 1\n                        else:\n                            status = \"STALE\"\n                    except:\n                        status = \"ERROR\"\n            \n            print(f\"  - AppID {app_id}: {status} {pid_info}\")\n    else:\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                content = f.read().strip()\n                try:\n                    pid = int(content)\n                    if is_running(pid):\n                        print(f\"STATUS: ACTIVE (PID: {pid})\")\n                        active_workers = 1\n                        return\n                    else:\n                        print(\"STATUS: INACTIVE (Stale PID file found)\")\n                except Exception as e:\n                    print(f\"STATUS: ERROR (Corrupted PID file): {e}\")\n        else:\n            print(\"STATUS: INACTIVE\")\n    \n    print(f\"TOTAL ACTIVE WORKERS: {active_workers}\")\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Bot Control Interface\")\n    parser.add_argument('command', choices=['/start_bot', '/stop_bot', '/status', '/monitor'], help=\"Command to execute\")\n    \n    if len(sys.argv) < 2:\n        parser.print_help()\n        sys.exit(1)\n\n    args = parser.parse_args()\n\n    if args.command == '/start_bot':\n        start_bot()\n    elif args.command == '/stop_bot':\n        stop_bot()\n    elif args.command == '/status':\n        status_bot()\n    elif args.command == '/monitor':\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Starting protocol monitor...\")\n        monitor_protocol()\n\nif __name__ == \"__main__\":\n    main()","file_path":"src/agent_wrapper.py"},"thoughtSignature":""}],"api":"google-vertex","provider":"google-vertex","model":"gemini-3-pro-preview","usage":{"input":11719,"output":2930,"cacheRead":8580,"cacheWrite":0,"totalTokens":14649,"cost":{"input":0.023438,"output":0.035160000000000004,"cacheRead":0.001716,"cacheWrite":0,"total":0.060314000000000006}},"stopReason":"toolUse","timestamp":1771162324110}}
