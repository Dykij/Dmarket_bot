\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000 \u0000-\u0000m\u0000 \u0000s\u0000r\u0000c\u0000.\u0000c\u0000l\u0000i\u0000.\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000a\u0000s\u0000y\u0000n\u0000c\u0000 \u0000d\u0000e\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000(\u0000c\u0000t\u0000x\u0000:\u0000 \u0000c\u0000l\u0000i\u0000c\u0000k\u0000.\u0000C\u0000o\u0000n\u0000t\u0000e\u0000x\u0000t\u0000,\u0000 \u0000p\u0000l\u0000a\u0000t\u0000f\u0000o\u0000r\u0000m\u0000:\u0000 \u0000s\u0000t\u0000r\u0000)\u0000 \u0000-\u0000>\u0000 \u0000N\u0000o\u0000n\u0000e\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000-\u0000p\u0000l\u0000a\u0000t\u0000f\u0000o\u0000r\u0000m\u0000 \u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000p\u0000 \u0000w\u0000a\u0000x\u0000p\u0000e\u0000e\u0000r\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000p\u0000 \u0000a\u0000l\u0000l\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000d\u0000a\u0000t\u0000a\u0000 \u0000=\u0000 \u0000a\u0000w\u0000a\u0000i\u0000t\u0000 \u0000a\u0000p\u0000i\u0000.\u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000(\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000r\u0000e\u0000s\u0000u\u0000l\u0000t\u0000s\u0000[\u0000\"\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000\"\u0000]\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000d\u0000a\u0000t\u0000a\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000d\u0000a\u0000t\u0000a\u0000 \u0000=\u0000 \u0000a\u0000w\u0000a\u0000i\u0000t\u0000 \u0000a\u0000p\u0000i\u0000.\u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000(\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000\"\u0000w\u0000a\u0000l\u0000l\u0000e\u0000t\u0000_\u0000u\u0000s\u0000d\u0000\"\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000d\u0000a\u0000t\u0000a\u0000.\u0000w\u0000a\u0000l\u0000l\u0000e\u0000t\u0000)\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000\"\u0000c\u0000a\u0000n\u0000_\u0000t\u0000r\u0000a\u0000d\u0000e\u0000\"\u0000:\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000d\u0000a\u0000t\u0000a\u0000.\u0000c\u0000a\u0000n\u0000_\u0000t\u0000r\u0000a\u0000d\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000c\u0000o\u0000p\u0000i\u0000l\u0000o\u0000t\u0000_\u0000c\u0000l\u0000i\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000\"\u0000u\u0000s\u0000d\u0000\"\u0000 \u0000i\u0000n\u0000 \u0000k\u0000e\u0000y\u0000.\u0000l\u0000o\u0000w\u0000e\u0000r\u0000(\u0000)\u0000 \u0000o\u0000r\u0000 \u0000k\u0000e\u0000y\u0000 \u0000=\u0000=\u0000 \u0000\"\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\"\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000c\u0000l\u0000i\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u00