u0000\u0000\u0000\u0000r\u0000_\u0000\u0000\u0000\u0000\u0000\u0000\u0000r\u0000K\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\u000f\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000r\u0000D\u0000\u0000\u0000\u0000\u0000\u0000\u0000r\u0000L\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\f\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000d\u0000a\u0000t\u0000e\u0000r\u0000u\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\u0007\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000\f%\u000b\u0000p\u0000r\u0000i\u0000c\u0000e\u0000_\u0000p\u0000o\u0000i\u0000n\u0000t\u0000r\u0000]\u0000\u0000\u0000\u0000\u0000\u0000\u0000r\u0000g\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000L\u0000i\u0000s\u0000t\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000v\u0000a\u0000l\u0000u\u0000e\u0000s\u0000 \u0000o\u0000v\u0000e\u0000r\u0000 \u0000t\u0000i\u0000m\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000L\u0000i\u0000s\u0000t\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000v\u0000a\u0000l\u0000u\u0000e\u0000s\u0000 \u0000o\u0000v\u0000e\u0000r\u0000 \u0000t\u0000i\u0000m\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000a\u0000s\u0000y\u0000n\u0000c\u0000 \u0000d\u0000e\u0000f\u0000 \u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000(\u0000s\u0000e\u0000l\u0000f\u0000)\u0000 \u0000-\u0000>\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000G\u0000e\u0000t\u0000 \u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000 \u0000U\u0000S\u0000D\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000.\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000E\u0000n\u0000d\u0000p\u0000o\u0000i\u0000n\u0000t\u0000:\u0000 \u0000/\u0000a\u0000c\u0000c\u0000o\u0000u\u0000n\u0000t\u0000/\u0000v\u00001\u0000/\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000R\u0000e\u0000t\u0000u\u0000r\u0000n\u0000s\u0000:\u0000 \u0000B\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000i\u0000n\u0000 \u0000U\u0000S\u0000D\u0000 \u0000(\u0000f\u0000l\u0000o\u0000a\u0000t\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000d\u0000a\u0000t\u0000a\u0000 \u0000=\u0000 \u0000a\u0000w\u0000a\u0000i\u0000t\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000_\u0000r\u0000e\u0000q\u0000u\u0000e\u0000s\u0000t\u0000(\u0000\"\u0000G\u0000E\u0000T\u0000\"\u0000,\u0000 \u0000\"\u0000/\u0000a\u0000c\u0000c\u0000o\u0000u\u0000n\u0000t\u0000/\u0000v\u00001\u0000/\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\"\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000h\u0000e\u0000a\u0000l\u0000t\u0000h\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000a\u0000w\u0000a\u0000i\u0000t\u0000 \u0000a\u0000p\u0000i\u0000_\u0000c\u0000l\u0000i\u0000e\u0000n\u0000t\u0000.\u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000(\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000n\u00008\u0000n\u0000_\u0000i\u0000n\u0000t\u0000e\u0000g\u0000r\u0000a\u0000t\u0000i\u0000o\u0000n\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u00002\u0000.\u0000 \u0000C\u0000h\u0000e\u0000c\u0000k\u0000 \u0000u\u0000s\u0000e\u0000r\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000s\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000G\u0000e\u0000t\u0000 \u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000 \u0000U\u0000S\u0000D\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000.\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000E\u0000n\u0000d\u0000p\u0000o\u0000i\u0000n\u0000t\u0000:\u0000 \u0000/\u0000a\u0000c\u0000c\u0000o\u0000u\u0000n\u0000t\u0000/\u0000v\u00001\u0000/\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000R\u0000e\u0000t\u0000u\u0000r\u0000n\u0000s\u0000:\u0000 \u0000B\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000i\u0000n\u0000 \u0000U\u0000S\u0000D\u0000 \u0000(\u0000f\u0000l\u0000o\u0000a\u0000t\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000p\u0000i\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000d\u0000m\u0000a\u0000r\u0000k\u0000e\u0000t\u0000.\u0000c\u0000p\u0000y\u0000t\u0000h\u0000o\u0000n\u0000-\u00003\u00001\u00001\u0000.\u0000p\u0000y\u0000c\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000r\u0000?\u0004\u0000\u0000\u0000\u0000\u0000\u0000z\u0000\u0013\u0000/\u0000a\u0000c\u0000c\u0000o\u0000u\u0000n\u0000t\u0000/\u0000v\u00001\u0000/\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000N\u0000\f%\u0003\u0000u\u0000s\u0000d\u0000r\u0000\u0002\u0000\u0000\u0000\u0000\u0000\u0000\u0000g\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000\u0000Y\u0000@\u0000)\u0000\u0004\u0000r\u0000/\u0004\u0000\u0000\u0000\u0000\u0000\u0000r\u0000?\u0000\u0000\u0000\u0000\u0000\u0000\u0000r\u0000�%\u0000\u0000\u0000\u0000\u0000\u0000\f%\u0005\u0000f\u0000l\u0000o\u0000a\u0000t\u0000)\u0000\u0003\u0000r\u0000+\u0000\u0000\u0000\u0000\u0000\u0000\u0000r\u0000~\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\u0005\u0000c\u0000e\u0000n\u0000t\u0000s\u0000s\u0000\u0003\u0000\u0000\u0000\u0000\u0000\u0000\u0000 \u0000 \u0000 \u0000r\u0000\u0019\u0000\u0000\u0000\u0000\u0000\u0000\u0000\f%\u000b\u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000z\u0000\u0016\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000A\u0000P\u0000I\u0000.\u0000g\u0000e\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000@\u0000\u0001\u0000\u0000\u0000\u0000\u0000s\u0000Z\u0000\u0000\u0000\u0000\u0000\u0000\u0000H\u0004\u0000\u0000H\u0004\u0000\u0000\u0010\u0004\u0000\u0000\u0001\u0004\f\u0000\u0000\u0000\u0016\u0000\u001a\u0000'\u0004]\u0000\"\u0004]\u00000\u00045\u0000h%*\u0000?\u0000d%\u0015\u0000@\u0000X%\u0015\u0000@\u0000h%\u000f\u0000@\u0000h%\u000f\u0000@\u0000h%\u000f\u0000@\u0000h%\u000f\u0000@\u0000h%\u000f\u0000@\u0000h%\u000f\u0000@\u0000\u0018\u0004\u0004\u0000E\u0004\u0010\u0000\u0013\u0000 \u0004D\u0000'\u0004H\u0000\"\u0004H\u0000(\u0004U\u00000\u0004A\u0000d%\u0014\u0000&\u0000X%\u0014\u0000&\u0000d%\u001