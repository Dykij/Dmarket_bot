\u00001\u0000.\u00005\u0000-\u0000f\u0000l\u0000a\u0000s\u0000h\u0000)\u0000\u0003\u0000\f%\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000 \u0000=\u0000 \u00000\u0000.\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000 \u0000=\u0000 \u00000\u0000.\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000S\u0000t\u0000a\u0000r\u0000t\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000f\u0000o\u0000r\u0000 \u0000s\u0000i\u0000m\u0000u\u0000l\u0000a\u0000t\u0000i\u0000o\u0000n\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000 \u0000=\u0000 \u00001\u00000\u00000\u0000.\u00000\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000S\u0000t\u0000a\u0000r\u0000t\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000f\u0000o\u0000r\u0000 \u0000s\u0000i\u0000m\u0000u\u0000l\u0000a\u0000t\u0000i\u0000o\u0000n\u0000 \u0000(\u0000U\u0000S\u0000D\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000>\u0000>\u0000>\u0000 \u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000 \u0000=\u0000 \u0000A\u0000I\u0000B\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000(\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00001\u00000\u00000\u0000.\u00000\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000#\u0000 \u0000R\u0000e\u0000s\u0000e\u0000t\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000a\u0000n\u0000d\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000>\u0000=\u0000 \u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000p\u0000r\u0000i\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000T\u0000r\u0000a\u0000d\u0000e\u0000 \u0000o\u0000b\u0000j\u0000e\u0000c\u0000t\u0000 \u0000o\u0000r\u0000 \u0000N\u0000o\u0000n\u0000e\u0000 \u0000i\u0000f\u0000 \u0000i\u0000n\u0000s\u0000u\u0000f\u0000f\u0000i\u0000c\u0000i\u0000e\u0000n\u0000t\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000<\u0000 \u0000p\u0000r\u0000i\u0000c\u0000e\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000=\u0000 \u0000t\u0000o\u0000t\u0000a\u0000l\u0000_\u0000c\u0000o\u0000s\u0000t\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000+\u0000=\u0000 \u0000n\u0000e\u0000t\u0000_\u0000p\u0000r\u0000o\u0000c\u0000e\u0000e\u0000d\u0000s\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000r\u0000o\u0000i\u0000_\u0000p\u0000e\u0000r\u0000c\u0000e\u0000n\u0000t\u0000 \u0000=\u0000 \u0000(\u0000t\u0000o\u0000t\u0000a\u0000l\u0000_\u0000p\u0000r\u0000o\u0000f\u0000i\u0000t\u0000 \u0000/\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000 \u0000*\u0000 \u00001\u00000\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000s\u0000e\u0000l\u0000f\u0000.\u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000#\u0000 \u0000T\u0000r\u0000a\u0000c\u0000k\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000o\u0000v\u0000e\u0000r\u0000 \u0000t\u0000i\u0000m\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000=\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000p\u0000r\u0000i\u0000c\u0000e\u0000 \u0000+\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000c\u0000o\u0000m\u0000m\u0000i\u0000s\u0000s\u0000i\u0000o\u0000n\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000+\u0000=\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000p\u0000r\u0000i\u0000c\u0000e\u0000 \u0000-\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000c\u0000o\u0000m\u0000m\u0000i\u0000s\u0000s\u0000i\u0000o\u0000n\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000m\u0000a\u0000x\u0000(\u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000>\u0000 \u00000\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000d\u0000r\u0000a\u0000w\u0000d\u0000o\u0000w\u0000n\u0000 \u0000=\u0000 \u0000(\u0000(\u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000 \u0000/\u0000 \u0000p\u0000e\u0000a\u0000k\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000 \u0000*\u0000 \u00001\u00000\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000 \u0000=\u0000 \u00001\u00000\u00000\u0000.\u00000\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000S\u0000t\u0000a\u0000r\u0000t\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000f\u0000o\u0000r\u0000 \u0000s\u0000i\u0000m\u0000u\u0000l\u0000a\u0000t\u0000i\u0000o\u0000n\u0000s\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000>\u0000>\u0000>\u0000 \u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000 \u0000=\u0000 \u0000c\u0000r\u0000e\u0000a\u0000t\u0000e\u0000_\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000(\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00005\u00000\u00000\u0000.\u00000\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000S\u0000t\u0000a\u0000r\u0000t\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000E\u0000n\u0000d\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000=\u0000 \u00000\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000r\u0000e\u0000t\u0000u\u0000r\u0000n\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000(\u0000(\u0000s\u0000e\u0000l\u0000f\u0000.\u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000 \u0000/\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000*\u0000 \u00001\u00000\u00000\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000\"\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\"\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000(\u0000s\u0000e\u0000l\u0000f\u0000.\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000\"\u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\"\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000(\u0000s\u0000e\u0000l\u0000f\u0000.\u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000A\u0000v\u0000a\u0000i\u0000l\u0000a\u0000b\u0000l\u0000e\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000m\u0000a\u0000x\u0000_\u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000_\u0000p\u0000c\u0000t\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000 \u0000=\u0000 \u00000\u0000.\u00001\u0000,\u0000 \u0000 \u0000#\u0000 \u0000M\u0000a\u0000x\u0000 \u00001\u00000\u0000%\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000p\u0000e\u0000r\u0000 \u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000m\u0000a\u0000x\u0000_\u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000_\u0000p\u0000c\u0000t\u0000:\u0000 \u0000M\u0000a\u0000x\u0000 \u0000p\u0000e\u0000r\u0000c\u0000e\u0000n\u0000t\u0000a\u0000g\u0000e\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000p\u0000e\u0000r\u0000 \u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000m\u0000a\u0000x\u0000_\u0000s\u0000p\u0000e\u0000n\u0000d\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000*\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000(\u0000s\u0000t\u0000r\u0000(\u0000s\u0000e\u0000l\u0000f\u0000.\u0000m\u0000a\u0000x\u0000_\u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000_\u0000p\u0000c\u0000t\u0000)\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000 \u0000S\u0000t\u0000a\u0000r\u0000t\u0000i\u0000n\u0000g\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000\"\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\"\u0000:\u0000 \u0000f\u0000l\u0000o\u0000a\u0000t\u0000(\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000l\u0000i\u0000s\u0000t\u0000[\u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000]\u0000 \u0000=\u0000 \u0000[\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000]\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000+\u0000=\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000n\u0000e\u0000t\u0000_\u0000a\u0000m\u0000o\u0000u\u0000n\u0000t\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000,\u0000 \u0000c\u0000u\u0000r\u0000r\u0000e\u0000n\u0000t\u0000_\u0000p\u0000r\u0000i\u0000c\u0000e\u0000,\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000 \u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000s\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000t\u0000o\u0000t\u0000a\u0000l\u0000_\u0000c\u0000o\u0000s\u0000t\u0000 \u0000<\u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000+\u0000=\u0000 \u0000t\u0000r\u0000a\u0000d\u0000e\u0000.\u0000n\u0000e\u0000t\u0000_\u0000a\u0000m\u0000o\u0000u\u0000n\u0000t\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000#\u0000 \u0000T\u0000r\u0000a\u0000c\u0000k\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000a\u0000t\u0000 \u0000e\u0000n\u0000d\u0000 \u0000o\u0000f\u0000 \u0000d\u0000a\u0000y\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000.\u0000a\u0000p\u0000p\u0000e\u0000n\u0000d\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000#\u0000 \u0000C\u0000a\u0000l\u0000c\u0000u\u0000l\u0000a\u0000t\u0000e\u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000i\u0000n\u0000c\u0000l\u0000u\u0000d\u0000i\u0000n\u0000g\u0000 \u0000o\u0000p\u0000e\u0000n\u0000 \u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000s\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000+\u0000=\u0000 \u0000l\u0000a\u0000s\u0000t\u0000_\u0000p\u0000r\u0000i\u0000c\u0000e\u0000 \u0000*\u0000 \u0000p\u0000o\u0000s\u0000i\u0000t\u0000i\u0000o\u0000n\u0000.\u0000q\u0000u\u0000a\u0000n\u0000t\u0000i\u0000t\u0000y\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000t\u0000o\u0000t\u0000a\u0000l\u0000_\u0000p\u0000r\u0000o\u0000f\u0000i\u0000t\u0000 \u0000=\u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000-\u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000m\u0000a\u0000x\u0000_\u0000d\u0000r\u0000a\u0000w\u0000d\u0000o\u0000w\u0000n\u0000 \u0000=\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000_\u0000c\u0000a\u0000l\u0000c\u0000u\u0000l\u0000a\u0000t\u0000e\u0000_\u0000m\u0000a\u0000x\u0000_\u0000d\u0000r\u0000a\u0000w\u0000d\u0000o\u0000w\u0000n\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000s\u0000h\u0000a\u0000r\u0000p\u0000e\u0000_\u0000r\u0000a\u0000t\u0000i\u0000o\u0000 \u0000=\u0000 \u0000s\u0000e\u0000l\u0000f\u0000.\u0000_\u0000c\u0000a\u0000l\u0000c\u0000u\u0000l\u0000a\u0000t\u0000e\u0000_\u0000s\u0000h\u0000a\u0000r\u0000p\u0000e\u0000_\u0000r\u0000a\u0000t\u0000i\u0000o\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u0000f\u0000i\u0000n\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000d\u0000e\u0000f\u0000 \u0000_\u0000c\u0000a\u0000l\u0000c\u0000u\u0000l\u0000a\u0000t\u0000e\u0000_\u0000m\u0000a\u0000x\u0000_\u0000d\u0000r\u0000a\u0000w\u0000d\u0000o\u0000w\u0000n\u0000(\u0000s\u0000e\u0000l\u0000f\u0000,\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000l\u0000i\u0000s\u0000t\u0000[\u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000]\u0000)\u0000 \u0000-\u0000>\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000L\u0000i\u0000s\u0000t\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000v\u0000a\u0000l\u0000u\u0000e\u0000s\u0000 \u0000o\u0000v\u0000e\u0000r\u0000 \u0000t\u0000i\u0000m\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000l\u0000e\u0000n\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000)\u0000 \u0000<\u0000 \u00002\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000p\u0000e\u0000a\u0000k\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u00000\u0000]\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000o\u0000r\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000i\u0000n\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u00001\u0000:\u0000]\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000>\u0000 \u0000p\u0000e\u0000a\u0000k\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000p\u0000e\u0000a\u0000k\u0000 \u0000=\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000d\u0000r\u0000a\u0000w\u0000d\u0000o\u0000w\u0000n\u0000 \u0000=\u0000 \u0000(\u0000p\u0000e\u0000a\u0000k\u0000 \u0000-\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000)\u0000 \u0000/\u0000 \u0000p\u0000e\u0000a\u0000k\u0000 \u0000i\u0000f\u0000 \u0000p\u0000e\u0000a\u0000k\u0000 \u0000>\u0000 \u00000\u0000 \u0000e\u0000l\u0000s\u0000e\u0000 \u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000(\u00000\u0000)\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000l\u0000i\u0000s\u0000t\u0000[\u0000D\u0000e\u0000c\u0000i\u0000m\u0000a\u0000l\u0000]\u0000,\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000:\u0000 \u0000L\u0000i\u0000s\u0000t\u0000 \u0000o\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000 \u0000v\u0000a\u0000l\u0000u\u0000e\u0000s\u0000 \u0000o\u0000v\u0000e\u0000r\u0000 \u0000t\u0000i\u0000m\u0000e\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000l\u0000e\u0000n\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000)\u0000 \u0000<\u0000 \u00002\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000f\u0000o\u0000r\u0000 \u0000i\u0000 \u0000i\u0000n\u0000 \u0000r\u0000a\u0000n\u0000g\u0000e\u0000(\u00001\u0000,\u0000 \u0000l\u0000e\u0000n\u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000)\u0000)\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000f\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u0000i\u0000 \u0000-\u0000 \u00001\u0000]\u0000 \u0000>\u0000 \u00000\u0000:\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000e\u0000r\u0000.\u0000p\u0000y\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000(\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u0000i\u0000]\u0000 \u0000-\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u0000i\u0000 \u0000-\u0000 \u00001\u0000]\u0000)\u0000 \u0000/\u0000 \u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000_\u0000h\u0000i\u0000s\u0000t\u0000o\u0000r\u0000y\u0000[\u0000i\u0000 \u0000-\u0000 \u00001\u0000]\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000S\u0000K\u0000I\u0000L\u0000L\u0000_\u0000B\u0000A\u0000C\u0000K\u0000T\u0000E\u0000S\u0000T\u0000I\u0000N\u0000G\u0000.\u0000m\u0000d\u0000:\u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00001\u00000\u00000\u0000.\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000S\u0000K\u0000I\u0000L\u0000L\u0000_\u0000B\u0000A\u0000C\u0000K\u0000T\u0000E\u0000S\u0000T\u0000I\u0000N\u0000G\u0000.\u0000m\u0000d\u0000:\u0000#\u0000#\u0000#\u0000#\u0000 \u0000`\u0000a\u0000s\u0000y\u0000n\u0000c\u0000 \u0000r\u0000u\u0000n\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0000(\u0000s\u0000t\u0000r\u0000a\u0000t\u0000e\u0000g\u0000y\u0000,\u0000 \u0000g\u0000a\u0000m\u0000e\u0000,\u0000 \u0000s\u0000t\u0000a\u0000r\u0000t\u0000_\u0000d\u0000a\u0000t\u0000e\u0000,\u0000 \u0000e\u0000n\u0000d\u0000_\u0000d\u0000a\u0000t\u0000e\u0000,\u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00001\u00000\u00000\u0000.\u00000\u0000)\u0000`\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000S\u0000K\u0000I\u0000L\u0000L\u0000_\u0000B\u0000A\u0000C\u0000K\u0000T\u0000E\u0000S\u0000T\u0000I\u0000N\u0000G\u0000.\u0000m\u0000d\u0000:\u0000-\u0000 \u0000`\u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000`\u0000 \u0000(\u0000f\u0000l\u0000o\u0000a\u0000t\u0000)\u0000:\u0000 \u0000h%-\u0004h%�%d%\u0017\u0004h%�%h%W%d%\u001c\u0004h%\\%d%\u001b\u0004h%c% \u0000h%�%h%�%h%W%h%�%h%\\%d%\u0011\u0004\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000S\u0000K\u0000I\u0000L\u0000L\u0000_\u0000B\u0000A\u0000C\u0000K\u0000T\u0000E\u0000S\u0000T\u0000I\u0000N\u0000G\u0000.\u0000m\u0000d\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00001\u00000\u00000\u0000.\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000S\u0000K\u0000I\u0000L\u0000L\u0000_\u0000B\u0000A\u0000C\u0000K\u0000T\u0000E\u0000S\u0000T\u0000I\u0000N\u0000G\u0000.\u0000m\u0000d\u0000:\u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000 \u0000i\u0000n\u0000i\u0000t\u0000i\u0000a\u0000l\u0000_\u0000b\u0000a\u0000l\u0000a\u0000n\u0000c\u0000e\u0000=\u00001\u00000\u00000\u0000.\u00000\u0000\r\u0000\n\u0000D\u0000:\u0000\\\u0000D\u0000M\u0000a\u0000r\u0000k\u0000e\u0000t\u0000-\u0000T\u0000e\u0000l\u0000e\u0000g\u0000r\u0000a\u0000m\u0000-\u0000B\u0000o\u0000t\u0000-\u0000m\u0000a\u0000i\u0000n\u0000\\\u0000s\u0000r\u0000c\u0000\\\u0000a\u0000n\u0000a\u0000l\u0000y\u0000t\u0000i\u0000c\u0000s\u0000\\\u0000_\u0000_\u0000p\u0000y\u0000c\u0000a\u0000c\u0000h\u0000e\u0000_\u0000_\u0000\\\u0000a\u0000i\u0000_\u0000b\u0000a\u0000c\u0000k\u0000t\u0000e\u0000s\u0000t\u0