t structure\" [level=5] [ref=e627]\n                - generic [ref=e628]:\n                  - code [ref=e630]: \"{ \\\"name\\\": \\\"string\\\", \\\"data\\\": { \\\"can_p2p\\\": \\\"boolean\\\" } }\"\n                  - button \"\" [ref=e631] [cursor=pointer]:\n                    - generic [ref=e632]: \n            - generic [ref=e635]:\n              - generic [ref=e636]: Example\n              - generic [ref=e638]:\n                - code [ref=e640]:\n                  - text: \"{ \\\"name\\\": \\\"user_change\\\", \\\"data\\\": { \\\"can_p2p\\\":\"\n                  - generic [ref=e641]: \"true\"\n                  - text: \"} }\"\n                - button \"\" [ref=e642] [cursor=pointer]:\n                  - generic [ref=e643]: \n          - generic [ref=e644]:\n            - generic [ref=e645]: Create trade\n            - generic [ref=e646]:\n              - generic [ref=e647]:\n                - generic [ref=e649]: send-trade\n                - paragraph [ref=e652]: Event for trade creation with all necessary data\n              - generic [ref=e653]:\n                - heading \"Event parameters\" [level=5] [ref=e656]\n                - table [ref=e657]:\n                  - rowgroup [ref=e658]:\n                    - row \"Parameter Type Description\" [ref=e659]:\n                      - columnheader \"Parameter\" [ref=e660]:\n                        - generic [ref=e661]: Parameter\n                      - columnheader \"Type\" [ref=e662]:\n                        - generic [ref=e663]: Type\n                      - columnheader \"Description\" [ref=e664]:\n                        - generic [ref=e665]: Description\n                  - rowgroup [ref=e666]:\n                    - row \"name string always “send-trade”\" [ref=e667]:\n                      - cell \"name\" [ref=e668]:\n                        - generic [ref=e669]: name\n                      - cell \"string\" [ref=e670]:\n                        - generic [ref=e671]: string\n               