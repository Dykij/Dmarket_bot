onse\" [level=5] [ref=e952]\n                - table [ref=e953]:\n                  - rowgroup [ref=e954]:\n                    - row \"Code Description\" [ref=e955]:\n                      - columnheader \"Code\" [ref=e956]:\n                        - generic [ref=e957]: Code\n                      - columnheader \"Description\" [ref=e958]:\n                        - generic [ref=e959]: Description\n                  - rowgroup [ref=e960]:\n                    - row \"200 successful operation\" [ref=e961]:\n                      - cell \"200\" [ref=e962]:\n                        - generic [ref=e963]: \"200\"\n                      - cell \"successful operation\" [ref=e964]:\n                        - generic [ref=e965]: successful operation\n                    - row \"403 Wrong or missing API key\" [ref=e966]:\n                      - cell \"403\" [ref=e967]:\n                        - generic [ref=e968]: \"403\"\n                      - cell \"Wrong or missing API key\" [ref=e969]:\n                        - generic [ref=e970]: Wrong or missing API key\n                    - row [ref=e971]:\n                      - cell [ref=e972]\n                      - cell [ref=e973]\n            - generic [ref=e975]:\n              - generic [ref=e976]:\n                - generic [ref=e977]: Example response (200)\n                - generic [ref=e979]:\n                  - code [ref=e981]:\n                    - text: \"{ \\\"success\\\":\"\n                    - generic [ref=e982]: \"true\"\n                    - text: \", \\\"user\\\": { \\\"wallet\\\": 1000, \\\"id\\\": \\\"11d6f117-1ad2-47e1-aca1-bcasdf9e37fa\\\", \\\"userid\\\": 1, \\\"id64\\\": \\\"765611983383140000\\\", \\\"avatar\\\": \\\"https://www.gravatar.com/avatar/31609d41eb6ccb405b1984967693de76?d=identicon&r=pg&s=32\\\", \\\"name\\\": \\\"WAXPEER\\\", \\\"sell_fees\\\": 0.95, \\\"can_p2p\\\":\"\n                    - generic [ref=e983]: \"true\"\n                    - text: \", \\\"tradelink\\\": \\\"https://steamcommunity.com/tradeoffer/new/?partner=378049039&token=XWpC4ZTT\\\", \\\"login\\\": \\\"makc\\\", \\\"ref\\\": \\\"waxpeer\\\", \\\"sell_status\\\":\"\n                    - generic [ref=e984]: \"true\"\n                    - text: \", \\\"steam_api\\\": \\\"54###A171A5C7B08CA287A###228C029\\\", \\\"total_hold_amount\\\"NEW: 5000 } }\"\n                  - button \"\" [ref=e985] [cursor=pointer]:\n                    - generic [ref=e986]: \n              - generic [ref=e987]:\n                - generic [ref=e988]: Example response (403)\n                - generic [ref=e990]:\n                  - code [ref=e992]:\n                    - text: \"{ \\\"success\\\":\"\n                    - generic [ref=e993]: \"false\"\n                    - text: \", \\\"msg\\\": \\\"Missing API\\\" }\"\n                  - button \"\" [ref=e994] [cursor=pointer]:\n                    - generic [ref=e995]: \n          - generic [ref=e996]:\n            - generic [ref=e997]: Create a new user and obtain a unique API key or get an API key from an already created account without Steam OAuth\n            - generic [ref=e998]:\n              - generic [ref=e999]:\n                - link \"Try in Swagger\" [ref=e1000] [cursor=pointer]:\n                  - /url: https://api.waxpeer.com/docs/#/User/post_v1_user\n                - generic [ref=e1001]:\n                  - text: POST\n                  - generic [ref=e1002]: /v1/user\n                - generic [ref=e1004]:\n                  - paragraph [ref=e1005]: \"**Create a new user and obtain a unique API key or get an API key from an already created account without Steam OAuth.**\"\n                  - paragraph [ref=e1006]: Both accounts must be unrestricted on Waxpeer.\n                  - paragraph [ref=e1007]: Target account must be new on Waxpeer or have no active 2fa and enabled the collection of account information (You can enable it on the site if it is turned off).\n                  - paragraph [ref=e1008]: \"**The token will not be used as a cookie in Steam during the API key creation/get process.**\"\n              - generic [ref=e1009]:\n                - generic [ref=e1011]:\n                  - heading \"Query parameters\" [level=5] [ref=e1012]\n                  - paragraph [ref=e1013]: \"* required\"\n                - table [ref=e1014]:\n                  - rowgroup [ref=e1015]:\n                    - row \"Parameter Type Description\" [ref=e1016]:\n                      - columnheader \"Parameter\" [ref=e1017]:\n                        - generic [ref=e1018]: Parameter\n                      - columnheader \"Type\" [ref=e1019]:\n                        - generic [ref=e1020]: Type\n                      - columnheader \"Description\" [ref=e1021]:\n                        - generic [ref=e1022]: Description\n                  - rowgroup [ref=e1023]:\n                    - row \"api * string Your WAXPEER API of creator account\" [ref=e1024]:\n                      - cell \"api *\" [ref=e1025]:\n                        - generic [ref=e1026]:\n                          - text: api\n                          - generic [ref=e1027]: \"*\"\n                      - cell \"string\" [ref=e1028]:\n                        - generic [ref=e1029]: string\n                      - cell \"Your WAXPEER API of creator account\" [ref=e1030]:\n                        - generic [ref=e1031]:\n                          - text: Your\n                          - generic [ref=e1032]:\n                            - link \"WAXPEER API\" [ref=e1033] [cursor=pointer]:\n                              - /url: https://waxpeer.com/profile/user\n                            - text: of creator account\n              - generic [ref=e1034]:\n                - generic [ref=e1035]:\n                  - generic [ref=e1036]:\n                    - heading \"Example body\" [level=5] [ref=e1037]\n                    - paragraph [ref=e1038]: \"* required\"\n                  - generic [ref=e1040]:\n                    - paragraph [ref=e1041]: Your Steam access token from the target account.\n                    - paragraph [ref=e1042]: \"**Token should be in base64 format and belong to your target account.**\"\n                - generic [ref=e1043]:\n                  - code [ref=e1045]: \"{ \\\"token\\\": \\\"ZXlKaGJHY2lPaUpJVXpJMU5pSXNJblI1Y0NJNklrcFhWQ0o5LmV5SnpkV0lpT2lJeE1qTTBOVFkzT0Rrd0lpd2libUZ0WlNJNklrcHZhRzRnUkc5bElpd2lhV0YwSWpveE5URTJNak01TURJeWZRLlNmbEt4d1JKU01lS0tGMlFUNGZ3cE1lSmYzNlBPazZ5SlZfYWRRc3N3NWM=\\\" }\"\n                  - button \"\" [ref=e1046] [cursor=pointer]:\n                    - generic [ref=e1047]: \n              - generic [ref=e1048]:\n                - heading \"Response\" [level=5] [ref=e1051]\n                - table [ref=e1052]:\n                  - rowgroup [ref=e1053]:\n                    - row \"Code Description\" [ref=e1054]:\n                      - columnheader \"Code\" [ref=e1055]:\n                        - generic [ref=e1056]: Code\n                      - columnheader \"Description\" [ref=e1057]:\n                        - generic [ref=e1058]: Description\n                  - rowgroup [ref=e1059]:\n                    - row \"200 successful operation **Please open the response schema if you need more information about the response parameters**\" [ref=e1060]:\n                      - cell \"200\" [ref=e1061]:\n                        - generic [ref=e1062]: \"200\"\n                      - cell \"successful operation **Please open the response schema if you need more information about the response parameters**\" [ref=e1063]:\n                        - generic [ref=e1064]: successful operation **Please open the response schema if you need more information about the response parameters**\n                    - row \"403 Wrong or missing Waxpeer API key of creator account\" [ref=e1065]:\n                      - cell \"403\" [ref=e1066]:\n                        - generic [ref=e1067]: \"403\"\n                      - cell \"Wrong or missing Waxpeer API key of creator account\" [ref=e1068]:\n                        - generic [ref=e1069]: Wrong or missing Waxpeer API key of creator account\n                    - row [ref=e1070]:\n                      - cell [ref=e1071]\n                      - cell [ref=e1072]\n            - generic [ref=e1074]:\n              - generic [ref=e1075]:\n                - generic [ref=e1076]: Example response (200)\n                - generic [ref=e1078]:\n                  - code [ref=e1080]:\n                    - text: \"{ \\\"success\\\":\"\n                    - generic [ref=e1081]: \"true\"\n                    - text: \", \\\"msg\\\": \\\"Need to refresh access token\\\", \\\"data\\\": { \\\"api\\\": \\\"1hbhbhodexkdei1axlc3ka7woibo2h16zoyidjv5wfwvqd6bty39e4086d110228\\\", \\\"isNew\\\":\"\n                    - generic [ref=e1082]: \"true\"\n                    - text: \"}, \\\"exp\\\": 1712852259 }\"\n                  - button \"\" [ref=e1083] [cursor=pointer]:\n                    - generic [ref=e1084]: \n              - generic [ref=e1085]:\n                - generic [ref=e1086]: Example response (403)\n                - generic [ref=e1088]:\n                  - code [ref=e1090]:\n                    - text: \"{ \\\"success\\\":\"\n                    - generic [ref=e1091]: \"false\"\n                    - text: \", \\\"msg\\\": \\\"Missing API\\\" }\"\n                  - button \"\" [ref=e1092] [cursor=pointer]:\n                    - generic [ref=e1093]: \n          - generic [ref=e1094]:\n            - generic [ref=e1095]: Temporary set Steam access token for user (Required for online)\n            - generic [ref=e1096]:\n              - generic [ref=e1097]:\n                - link \"Try in Swagger\" [ref=e1098] [cursor=pointer]:\n                  - /url: https://api.waxpeer.com/docs/#/User/post_v1_user_steam_token\n                - generic [ref=e1099]:\n                  - text: POST\n                  - generic [ref=e1100]: /v1/user/steam-token\n                - generic [ref=e1102]:\n                  - paragraph [ref=e1103]: Due to the steam update, it became mandatory to pass regularly (we recommend sending once an hour and keep 6 hours from the time we receive it) to be online and sell on the marketplace.\n                  - paragraph [ref=e1104]: \"**Token should be in base64 format and belong to your account.**\"\n                  - paragraph [ref=e1105]: It is recommended to transmit it once an hour to maintain validity, as well as in case of refreshing\n                  - paragraph [ref=e1106]: If the \"success\" parameter in the response is false, you will not get online and most likely you need to update the token and send a new one\n                  - paragraph [ref=e1107]: \"**The token will not be used as a cookie in Steam outside of your client.**\"\n              - generic [ref=e1108]:\n                - generic [ref=e1110]:\n                  - heading \"Query parameters\" [level=5] [ref=e1111]\n                  - paragraph [ref=e1112]: \"* required\"\n                - table [ref=e1113]:\n                  - rowgroup [ref=e1114]:\n                    - row \"Parameter Type Description\" [ref=e1115]:\n                      - columnheader \"Parameter\" [ref=e1116]:\n                        - generic [ref=e1117]: Parameter\n                      - columnheader \"Type\" [ref=e1118]:\n                        - generic [ref=e1119]: Type\n                      - columnheader \"Description\" [ref=e1120]:\n                        - generic [ref=e1121]: Description\n                  - rowgroup [ref=e1122]:\n                    - row \"api * string Your WAXPEER API\" [ref=e1123]:\n                      - cell \"api *\" [ref=e1124]:\n                        - generic [ref=e1125]:\n                          - text: api\n                          - generic [ref=e1126]: \"*\"\n                      - cell \"string\" [ref=e1127]:\n                        - generic [ref=e1128]: string\n                   