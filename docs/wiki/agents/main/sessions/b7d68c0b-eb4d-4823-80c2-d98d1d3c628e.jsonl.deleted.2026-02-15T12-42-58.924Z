r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\test_auto_listing.py                        \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\test_multi_platform_aggregator.py           \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\test_opportunity_scorer.py                  \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\__pycache__\\test_auto_listing.cpython-311...\r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\__pycache__\\test_multi_platform_aggregato...\r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\dmarket\\__pycache__\\test_opportunity_scorer.cpyth...\r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\e2e\\test_complete_arbitrage_flow.py                 \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\e2e\\test_strategy_e2e.py                            \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\e2e\\__pycache__\\test_complete_arbitrage_flow.cpyt...\r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\e2e\\__pycache__\\test_strategy_e2e.cpython-311-pyt...\r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\fixtures\\mock_responses.py                          \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\fixtures\\__init__.py                                \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\integration\\test_bot_integrator.py                  \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\integration\\test_n8n_workflows.py                   \r\nC:\\Users\\west2\\.openclaw\\workspace\\DMarket-Telegram-Bot-main\\tests\\integration\\__pycache__\\test_bot_integrator.cpyth...\r\nC:\\Users\\west2\\.opencla