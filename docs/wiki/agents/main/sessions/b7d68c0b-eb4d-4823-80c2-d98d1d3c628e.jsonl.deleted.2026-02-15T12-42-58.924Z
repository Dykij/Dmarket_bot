{"type":"message","id":"fadb6f25","parentId":"7438d931","timestamp":"2026-02-15T11:42:36.001Z","message":{"role":"toolResult","toolCallId":"read_1771155755857_442","toolName":"read","content":[{"type":"text","text":"# Configuration for development environment\r\n# Mock configuration for smoke test\r\n\r\nbot:\r\n  token: \"1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456789\"\r\n  username: \"dmarket_bot\"\r\n  webhook:\r\n    url: \"\"\r\n    secret: \"\"\r\n\r\ndmarket:\r\n  api_url: \"https://api.dmarket.com\"\r\n  public_key: \"aabbccddeeffgghhiijjkkllmmnnooppqqrrsstt\"\r\n  secret_key: \"11223344556677889900aabbccddeeffgghhiijj\"\r\n  rate_limit: 30\r\n\r\n# Waxpeer P2P Integration\r\nwaxpeer:\r\n  enabled: false\r\n  api_key: \"\"\r\n\r\n# Scanner configuration\r\nscanner:\r\n  max_concurrent_scans: 2\r\n  scan_interval_seconds: 10.0\r\n  adaptive:\r\n    enabled: true\r\n    min_interval: 2.5\r\n    max_interval: 10.0\r\n  parallel:\r\n    enabled: true\r\n    max_concurrent: 2\r\n  cleanup:\r\n    enabled: true\r\n    max_age_hours: 24\r\n    interval_minutes: 60\r\n\r\ndatabase:\r\n  url: \"sqlite:///data/dmarket_bot.db\"\r\n  echo: false\r\n  pool_size: 5\r\n  max_overflow: 10\r\n\r\nredis:\r\n  url: \"redis://localhost:6379\"\r\n\r\nlogging:\r\n  level: \"INFO\"\r\n  file: \"logs/dmarket_bot.log\"\r\n  format: \"%(asctime)s - %(name)s - %(levelname)s - %(message)s\"\r\n  rotation: \"1 week\"\r\n  retention: \"1 month\"\r\n\r\nsecurity:\r\n  allowed_users: []\r\n  admin_users: []\r\n\r\nanalytics:\r\n  enabled: true\r\n\r\nmonitoring:\r\n  sentry_dsn: \"\"\r\n  prometheus_enabled: false\r\n\r\ncache:\r\n  ttl: 300\r\n  max_size: 1000\r\n\r\narbitrage_filters:\r\n  enabled: true\r\n  min_avg_price: 0.50\r\n  good_points_percent: 80\r\n  boost_percent: 150\r\n  min_sales_volume: 10\r\n  min_profit_margin: 5.0\r\n  outlier_threshold: 2.0\r\n  min_liquidity_score: 60\r\n  max_time_to_sell_days: 7\r\n\r\nmarket_analysis:\r\n  enabled: true\r\n  update_interval: 3600\r\n  top_items_count: 100\r\n  min_daily_volume: 50\r\n\r\ndiversification:\r\n  enabled: true\r\n  max_same_items_in_inventory: 5\r\n  max_single_item_percent: 25\r\n  min_different_items: 5\r\n  max_stack_value_percent: 15\r\n\r\ngame_strategy:\r\n  enabled: true\r\n  weights:\r\n    tf2: 30\r\n    csgo: 40\r\n    rust: 20\r\n    dota2: 10\r\n\r\nwhitelist:\r\n  enabled: true\r\n  file_path: \"data/whitelist.json\"\r\n  priority_only: false\r\n  buy_max_overpay_percent: 2.0\r\n\r\nauto_sell:\r\n  enabled: true\r\n  min_margin_percent: 4.0\r\n  max_margin_percent: 12.0\r\n  target_margin_percent: 8.0\r\n  undercut_cents: 1\r\n  price_check_interval_minutes: 30\r\n  stop_loss_hours: 48\r\n  stop_loss_percent: 5.0\r\n  max_active_sales: 50\r\n  delay_before_list_seconds: 5\r\n  pricing_strategy: \"undercut\"\r\n  dmarket_fee_percent: 7.0\r\n\r\nrepricing:\r\n  enabled: true\r\n  intervals:\r\n    - hours: 24\r\n      action: \"reduce_to_target\"\r\n    - hours: 48\r\n      action: \"reduce_to_break_even\"\r\n    - hours: 72\r\n      action: \"liquidate\"\r\n  max_price_cut_percent: 15\r\n  night_mode:\r\n    enabled: true\r\n    start_hour: 2\r\n    end_hour: 6\r\n    undercut_multiplier: 2.0\r\n\r\npanic_protection:\r\n  enabled: true\r\n  threshold_percent: 15\r\n  check_window_hours: 1\r\n  action: \"pause\"\r\n\r\nblacklist:\r\n  enabled: true\r\n  file_path: \"data/blacklist.json\"\r\n  auto_blacklist_threshold: 3\r\n  failure_expiry_hours: 24\r\n  forbidden_keywords:\r\n    - \"Souvenir\"\r\n    - \"Well-Worn\"\r\n    - \"Inscribed Gem\"\r\n    - \"StatTrak™ Music Kit\"\r\n    - \"Autograph\"\r\n\r\nmarket_sentiment:\r\n  enabled: true\r\n  check_interval_minutes: 15\r\n  panic_sell_threshold: -0.07\r\n  high_risk_hunt: true\r\n  speculative_budget_pct: 0.15\r\n\r\nsteam_parser:\r\n  enabled: true\r\n  cache_ttl: 300\r\n  max_concurrent_requests: 10\r\n  request_timeout: 5.0\r\n  use_proxy: false\r\n  proxy_url: \"\"\r\n  requests_per_minute: 30\r\n  arbitrage:\r\n    min_profit_percent: 15\r\n    max_discount_percent: 50\r\n\r\nintelligent_hold:\r\n  enabled: true\r\n  min_expected_gain: 10\r\n  max_hold_days: 14\r\n  profit_take_threshold: 20\r\n  loss_cut_days: 7\r\n  loss_cut_threshold: 5\r\n  event_sensitive_categories:\r\n    - \"stickers\"\r\n    - \"capsules\"\r\n    - \"cases\"\r\n\r\nai_training:\r\n  enabled: true\r\n  real_prices:\r\n    default_samples: 500\r\n    games: [\"csgo\", \"tf2\", \"dota2\", \"rust\"]\r\n    min_price_usd: 0.50\r\n    max_price_usd: 1000.0\r\n  liquid_training:\r\n    enabled: true\r\n    liquidity_threshold: 50\r\n    min_offers_dmarket: 3\r\n    min_offers_waxpeer: 5\r\n    whitelist_bonus: 25\r\n    whitelist_threshold: 40\r\n    use_waxpeer: true\r\n    use_steam: true\r\n  hallucination_protection:\r\n    enabled: true\r\n    max_profit_percent: 40\r\n    outlier_zscore_threshold: 3.0\r\n  data_paths:\r\n    market_history: \"data/market_history.csv\"\r\n    liquid_items: \"data/liquid_items.csv\"\r\n    model_path: \"data/price_model.pkl\"\r\n\r\nmoney_management:\r\n  enabled: true\r\n  small_balance_threshold: 100\r\n  medium_balance_threshold: 500\r\n  large_balance_threshold: 1000\r\n  max_item_percent:\r\n    small: 25\r\n    medium: 15\r\n    large: 10\r\n  min_item_percent: 0.5\r\n  reserve_percent: 5\r\n  target_roi:\r\n    small: 15.0\r\n    medium: 12.0\r\n    large: 8.0\r\n  balance_spike_threshold: 50\r\n  balance_spike_action: \"pause_and_confirm\"\r\n\r\nrate_limit:\r\n  warning_threshold: 0.9\r\n  enable_notifications: true\r\n  base_retry_delay: 1.0\r\n  max_backoff_time: 60.0\r\n  max_retry_attempts: 5\r\n  market_limit: 2\r\n  trade_limit: 1\r\n  user_limit: 5\r\n  balance_limit: 10\r\n  other_limit: 5\r\n"}],"isError":false,"timestamp":1771155756000}}
{"type":"message","id":"2d453e6d","parentId":"fadb6f25","timestamp":"2026-02-15T11:42:36.006Z","message":{"role":"toolResult","toolCallId":"read_1771155755978_443","toolName":"read","content":[{"type":"text","text":"# Feature Flags Configuration\r\n\r\n# Формат:\r\n# feature_name:\r\n#   enabled: true/false         # Глобально включен\r\n#   rollout_percent: 0-100      # Процент пользователей\r\n#   whitelist: [user_ids]       # Всегда включено для этих пользователей\r\n#   blacklist: [user_ids]       # Всегда выключено для этих пользователей\r\n#   conditions:                 # Условия включения\r\n#     key: value\r\n\r\nfeatures:\r\n  # Trading features\r\n  portfolio_management:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  auto_sell:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  hft_mode:\r\n    enabled: false  # Экспериментальная фича\r\n    rollout_percent: 10\r\n    whitelist: []  # Добавить ID админов/тестеров\r\n    blacklist: []\r\n\r\n  backtesting:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  # Arbitrage features\r\n  cross_game_arbitrage:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  intramarket_arbitrage:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  # AI/ML Training features (January 2026)\r\n  ai_real_price_training:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n    description: \"Train AI on real market prices from DMarket API\"\r\n\r\n  ai_liquid_training:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n    description: \"Train AI only on liquid items using DMarket, Waxpeer, Steam APIs\"\r\n\r\n  ai_hallucination_protection:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n    description: \"Protect AI from predicting unrealistic profits (max 40%)\"\r\n\r\n  # Analytics features\r\n  market_analytics:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  price_prediction:\r\n    enabled: true  # Now stable (January 2026)\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  competition_analysis:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  # Notification features\r\n  smart_notifications:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  discord_notifications:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  daily_reports:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  # Waxpeer integration features (January 2026)\r\n  waxpeer_integration:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n    description: \"Cross-platform arbitrage with Waxpeer\"\r\n\r\n  waxpeer_auto_listing:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  waxpeer_shadow_listing:\r\n    enabled: true\r\n    rollout_percent: 100\r\n    whitelist: []\r\n    blacklist: []\r\n\r\n  # Experimental features\r\n  experimental_ui:\r\n    enabled: false\r\n    rollout_percent: 0\r\n    whitelist: []  # Только для бета-тестеров\r\n    blacklist: []\r\n\r\n  beta_features:\r\n    enabled: false\r\n    rollout_percent: 0\r\n    whitelist: []  # Только для бета-тестеров\r\n    blacklist: []\r\n"}],"isError":false,"timestamp":1771155756005}}
