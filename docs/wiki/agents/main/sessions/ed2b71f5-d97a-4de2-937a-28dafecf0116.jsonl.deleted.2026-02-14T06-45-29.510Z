nerate_response(user_message)\n 26         await context.bot.send_message(chat_id=update.effective_chat.id, text=response)\n 27 \n 28     def run(self):\n 29         start_handler = CommandHandler('start', self.start)\n 30         chat_handler = MessageHandler(filters.TEXT & (~filters.COMMAND), self.chat)\n 31         \n 32         self.app.add_handler(start_handler)\n 33         self.app.add_handler(chat_handler)\n 34         \n 35         self.app.run_polling()\n 36 \n 37 if __name__ == '__main__':\n-38     bot = TelegramBot(\"TOKEN\")\n+45     TOKEN = os.environ.get(\"TELEGRAM_BOT_TOKEN\", \"YOUR_BOT_TOKEN\")\n+46     bot = TelegramBot(TOKEN)\n 39     bot.run()","firstChangedLine":3},"isError":false,"timestamp":1771007763438}}
