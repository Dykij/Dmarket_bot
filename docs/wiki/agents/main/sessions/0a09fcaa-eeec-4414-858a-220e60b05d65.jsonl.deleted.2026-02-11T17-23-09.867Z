          \r\nD:\\DMarket-Telegram-Bot-main\\src\\web_dashboard\\app.py                                                              \r\nD:\\DMarket-Telegram-Bot-main\\src\\web_dashboard\\__pycache__\\app.cpython-311.pyc                                     \r\nD:\\DMarket-Telegram-Bot-main\\src\\__pycache__\\containers.cpython-311.pyc                                            \r\nD:\\DMarket-Telegram-Bot-main\\src\\__pycache__\\interfaces.cpython-311.pyc                                            \r\nD:\\DMarket-Telegram-Bot-main\\src\\__pycache__\\main.cpython-311.pyc                                                  \r\nD:\\DMarket-Telegram-Bot-main\\src\\__pycache__\\__init__.cpython-311.pyc","cwd":"D:\\DMarket-Telegram-Bot-main"},"isError":false,"timestamp":1770826429786}}
