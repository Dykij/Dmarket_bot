{"type":"message","id":"165d9250","parentId":"309d38d7","timestamp":"2026-02-15T13:40:26.474Z","message":{"role":"toolResult","toolCallId":"read_1771162826206_147","toolName":"read","content":[{"type":"text","text":"import sys\nimport os\nimport subprocess\nimport argparse\nimport signal\nimport time\nimport threading\nimport json\n\nPID_FILE = \"src/bot.pid\"\nBOT_SCRIPT = \"src/trading_bot.py\"\nPROTOCOL_FILE = \"docs_archive/MASTER_PROTOCOL.md\"\nCONFIG_FILE = \"openclaw.json\"\n\n# AppIDs: CS2, Dota2, TF2, Rust\nFLEET_APPS = [\"730\", \"570\", \"440\", \"252490\"]\n\ndef load_config():\n    \"\"\"Load config from openclaw.json.\"\"\"\n    if os.path.exists(CONFIG_FILE):\n        try:\n            with open(CONFIG_FILE, 'r') as f:\n                return json.load(f)\n        except Exception as e:\n            print(f\"Error loading config: {e}\")\n    return {}\n\ndef reload_protocol():\n    \"\"\"Reloads the master protocol configuration.\"\"\"\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Hot Reload: Active\")\n\ndef monitor_protocol():\n    \"\"\"Monitors the protocol file for changes.\"\"\"\n    config = load_config()\n    sys_caps = config.get(\"system_capabilities\", {})\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Integrity: fleet_mode={config.get('fleet_mode')}, lazy_loading={sys_caps.get('lazy_loading')}, Ed25519={sys_caps.get('Ed25519')}\")\n\n    if not os.path.exists(PROTOCOL_FILE):\n        return\n\n    last_mtime = os.path.getmtime(PROTOCOL_FILE)\n    print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Monitoring {PROTOCOL_FILE} for changes...\")\n\n    while True:\n        try:\n            current_mtime = os.path.getmtime(PROTOCOL_FILE)\n            if current_mtime != last_mtime:\n                last_mtime = current_mtime\n                reload_protocol()\n            time.sleep(1)\n        except OSError:\n            pass\n        except Exception as e:\n            print(f\"Error monitoring protocol: {e}\")\n            time.sleep(5)\n\ndef is_running(pid):\n    \"\"\"Check if a process with the given PID is running.\"\"\"\n    try:\n        if os.name == 'nt':\n            output = subprocess.check_output(f'tasklist /FI \"PID eq {pid}\"', shell=True).decode(errors='ignore')\n            return str(pid) in output\n        else:\n            os.kill(pid, 0)\n            return True\n    except (OSError, subprocess.CalledProcessError):\n        return False\n\ndef start_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n\n    if fleet_mode:\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Fleet Mode: ACTIVE\")\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            print(f\"Worker for AppID {app_id} already running (PID: {pid}).\")\n                            continue\n                        else:\n                            print(f\"Found stale PID file for {app_id}. Cleaning up.\")\n                            os.remove(pid_file)\n                    except ValueError:\n                        print(f\"Invalid PID file for {app_id}. Cleaning up.\")\n                        os.remove(pid_file)\n\n            print(f\"Spawning worker for AppID {app_id}...\")\n            spawn_worker(app_id, pid_file)\n    else:\n        # Legacy single mode (defaulting to CS2/730 if not specified)\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                try:\n                    pid = int(f.read().strip())\n                    if is_running(pid):\n                        print(f\"Bot is already running (PID: {pid}).\")\n                        return\n                    else:\n                        print(\"Found stale PID file. Cleaning up.\")\n                except ValueError:\n                    print(\"Invalid PID file. Cleaning up.\")\n            \n            os.remove(PID_FILE)\n\n        print(\"Starting single bot instance...\")\n        spawn_worker(\"730\", PID_FILE)\n\ndef spawn_worker(app_id, pid_file):\n    args = [sys.executable, BOT_SCRIPT]\n    \n    env = os.environ.copy()\n    if app_id:\n        env[\"TARGET_APP_ID\"] = app_id\n\n    # Detached execution\n    if os.name == 'nt':\n        process = subprocess.Popen(\n            args,\n            creationflags=subprocess.CREATE_NEW_CONSOLE,\n            cwd=os.getcwd(),\n            env=env\n        )\n    else:\n        process = subprocess.Popen(\n            args,\n            stdout=subprocess.DEVNULL,\n            stderr=subprocess.DEVNULL,\n            stdin=subprocess.DEVNULL,\n            cwd=os.getcwd(),\n            start_new_session=True,\n            env=env\n        )\n\n    with open(pid_file, 'w') as f:\n        f.write(str(process.pid))\n    \n    print(f\"Worker for AppID {app_id} started with PID: {process.pid}\")\n\ndef stop_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    \n    pids_to_kill = []\n    \n    if fleet_mode:\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            if os.path.exists(pid_file):\n                pids_to_kill.append((f\"AppID {app_id}\", pid_file))\n    \n    # Check main PID file too\n    if os.path.exists(PID_FILE):\n        pids_to_kill.append((\"Main\", PID_FILE))\n\n    if not pids_to_kill:\n        print(\"No active bots found.\")\n        return\n\n    for label, pid_file in pids_to_kill:\n        with open(pid_file, 'r') as f:\n            try:\n                pid = int(f.read().strip())\n            except ValueError:\n                print(f\"Invalid PID file for {label}.\")\n                os.remove(pid_file)\n                continue\n\n        if is_running(pid):\n            print(f\"Stopping {label} worker (PID: {pid})...\")\n            try:\n                if os.name == 'nt':\n                    subprocess.call(['taskkill', '/F', '/T', '/PID', str(pid)])\n                else:\n                    os.kill(pid, signal.SIGTERM)\n            except Exception as e:\n                print(f\"Error stopping {label}: {e}\")\n        else:\n            print(f\"{label} process not found. Cleaning up PID file.\")\n\n        if os.path.exists(pid_file):\n            os.remove(pid_file)\n    print(\"All bots stopped.\")\n\ndef status_bot():\n    config = load_config()\n    fleet_mode = config.get(\"fleet_mode\", False)\n    active_workers = 0\n    \n    if fleet_mode:\n        print(f\"FLEET MODE: ENABLED\")\n        for app_id in FLEET_APPS:\n            pid_file = f\"src/bot_{app_id}.pid\"\n            status = \"INACTIVE\"\n            pid_info = \"\"\n            \n            if os.path.exists(pid_file):\n                with open(pid_file, 'r') as f:\n                    try:\n                        pid = int(f.read().strip())\n                        if is_running(pid):\n                            status = \"ACTIVE\"\n                            pid_info = f\"(PID: {pid})\"\n                            active_workers += 1\n                        else:\n                            status = \"STALE\"\n                    except:\n                        status = \"ERROR\"\n            \n            print(f\"  - AppID {app_id}: {status} {pid_info}\")\n    else:\n        if os.path.exists(PID_FILE):\n            with open(PID_FILE, 'r') as f:\n                content = f.read().strip()\n                try:\n                    pid = int(content)\n                    if is_running(pid):\n                        print(f\"STATUS: ACTIVE (PID: {pid})\")\n                        active_workers = 1\n                        return\n                    else:\n                        print(\"STATUS: INACTIVE (Stale PID file found)\")\n                except Exception as e:\n                    print(f\"STATUS: ERROR (Corrupted PID file): {e}\")\n        else:\n            print(\"STATUS: INACTIVE\")\n    \n    print(f\"TOTAL ACTIVE WORKERS: {active_workers}\")\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Bot Control Interface\")\n    parser.add_argument('command', choices=['/start_bot', '/stop_bot', '/status', '/monitor'], help=\"Command to execute\")\n    \n    if len(sys.argv) < 2:\n        parser.print_help()\n        sys.exit(1)\n\n    args = parser.parse_args()\n\n    if args.command == '/start_bot':\n        start_bot()\n    elif args.command == '/stop_bot':\n        stop_bot()\n    elif args.command == '/status':\n        status_bot()\n    elif args.command == '/monitor':\n        print(f\"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Starting protocol monitor...\")\n        monitor_protocol()\n\nif __name__ == \"__main__\":\n    main()"}],"isError":false,"timestamp":1771162826473}}
{"type":"message","id":"6c2b589f","parentId":"165d9250","timestamp":"2026-02-15T13:40:26.479Z","message":{"role":"toolResult","toolCallId":"read_1771162826316_148","toolName":"read","content":[{"type":"text","text":"import os\nimport sys\nimport subprocess\nimport logging\nimport asyncio\nfrom telegram import Update, BotCommand\nfrom telegram.ext import ApplicationBuilder, ContextTypes, CommandHandler\n\n# Configure logging\nlogging.basicConfig(\n    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',\n    level=logging.INFO\n)\n\n# Paths (Assuming run from workspace root)\nAGENT_WRAPPER = \"src/agent_wrapper.py\"\nPID_FILE = \"src/bot.pid\"\nMASTER_PROTOCOL = \"docs_archive/MASTER_PROTOCOL.md\"\nEVOLUTION_LOG = \"docs_archive/EVOLUTION_LOG.md\"\n\n# Token from Env\nTOKEN = os.getenv(\"TELEGRAM_BOT_TOKEN\")\n\nasync def dm_start(update: Update, context: ContextTypes.DEFAULT_TYPE):\n    \"\"\"ð Start DMarket HFT (High-Frequency)\"\"\"\n    await update.message.reply_text(\"ð Starting DMarket HFT Bot...\")\n    try:\n        # Run agent_wrapper from root\n        result = subprocess.run([sys.executable, AGENT_WRAPPER, \"/start_bot\"], capture_output=True, text=True)\n        \n        # Format output\n        output = result.stdout\n        if result.stderr:\n            output += \"\\nErrors:\\n\" + result.stderr\n            \n        await update.message.reply_text(f\"```\\n{output.strip()}\\n```\", parse_mode='Markdown')\n    except Exception as e:\n        await update.message.reply_text(f\"Failed to start bot: {e}\")\n\nasync def dm_stop(update: Update, context: ContextTypes.DEFAULT_TYPE):\n    \"\"\"ð EMERGENCY STOP & Flush\"\"\"\n    await update.message.reply_text(\"ð Stopping DMarket HFT Bot...\")\n    try:\n        result = subprocess.run([sys.executable, AGENT_WRAPPER, \"/stop_bot\"], capture_output=True, text=True)\n        \n        output = result.stdout\n        if result.stderr:\n            output += \"\\nErrors:\\n\" + result.stderr\n            \n        await update.message.reply_text(f\"```\\n{output.strip()}\\n```\", parse_mode='Markdown')\n    except Exception as e:\n        await update.message.reply_text(f\"Failed to stop bot: {e}\")\n\nasync def dm_status(update: Update, context: ContextTypes.DEFAULT_TYPE):\n    \"\"\"ð Bot Health & Balance\"\"\"\n    # Fleet Status\n    fleet_apps = [\"730\", \"570\", \"440\", \"252490\"]\n    active_count = 0\n    for app_id in fleet_apps:\n        if os.path.exists(f\"src/bot_{app_id}.pid\"):\n            active_count += 1\n            \n    # Security Status (Check if critical folders exist)\n    sec_active = os.path.exists(\"D:/Dmarket_bot/specs\") and os.path.exists(\"D:/Dmarket_bot/memory/checkpoints\")\n    sec_text = \"Active\" if sec_active else \"Warning\"\n\n    status_msg = (\n        f\"â Fleet: {active_count} Active\\n\"\n        f\"â Security: {sec_text}\\n\"\n        f\"âģ Profit: Calculating...\"\n    )\n\n    await update.message.reply_text(status_msg)\n\nasync def dm_dashboard(update: Update, context: ContextTypes.DEFAULT_TYPE):\n    \"\"\"ð Open Control Panel\"\"\"\n    # Assuming local streamlit or configured URL\n    url = os.getenv(\"STREAMLIT_URL\", \"http://localhost:8501\")\n    await update.message.reply_text(f\"ð **Control Panel:** [Open Dashboard]({url})\", parse_mode='Markdown')\n\nasync def post_init(application):\n    \"\"\"Set up commands on bot startup\"\"\"\n    commands = [\n        BotCommand(\"dm_start\", \"ð Start DMarket HFT\"),\n        BotCommand(\"dm_stop\", \"ð EMERGENCY STOP & Flush\"),\n        BotCommand(\"dm_status\", \"ð Bot Health & Balance\"),\n        BotCommand(\"dm_dashboard\", \"ð Open Control Panel\"),\n    ]\n    await application.bot.delete_my_commands()\n    await application.bot.set_my_commands(commands)\n    logging.info(\"Commands registered with Telegram.\")\n\nif __name__ == '__main__':\n    if not TOKEN:\n        print(\"Error: TELEGRAM_BOT_TOKEN not set. Please set it in your environment.\")\n        # For testing purposes, we might want to exit gracefully or mock it, \n        # but for a real deployment, we exit.\n        sys.exit(1)\n        \n    application = ApplicationBuilder().token(TOKEN).post_init(post_init).build()\n    \n    application.add_handler(CommandHandler('dm_start', dm_start))\n    application.add_handler(CommandHandler('dm_stop', dm_stop))\n    application.add_handler(CommandHandler('dm_status', dm_status))\n    application.add_handler(CommandHandler('dm_dashboard', dm_dashboard))\n    \n    print(\"Telegram Bot Control Interface Started.\")\n    application.run_polling()\n"}],"isError":false,"timestamp":1771162826477}}
{"type":"message","id":"82109ef3","parentId":"6c2b589f","timestamp":"2026-02-15T13:40:26.484Z","message":{"role":"toolResult","toolCallId":"read_1771162826444_149","toolName":"read","content":[{"type":"text","text":"import os\nimport sys\nimport json\nimport requests\nfrom dotenv import load_dotenv\n\n# Force UTF-8 encoding for stdout (Windows fix)\nsys.stdout.reconfigure(encoding='utf-8')\n\n# Try to load environment variables from .env file\nload_dotenv()\n\ndef refresh_menu():\n    \"\"\"\n    Refreshes the Telegram bot command menu with the requested global command set.\n    \"\"\"\n    # Check openclaw.json for command lock (extra safety)\n    try:\n        with open(\"openclaw.json\", \"r\") as f:\n            config = json.load(f)\n            if config.get(\"commands\") is not None:\n                print(\"â ïļ Warning: 'commands' in openclaw.json is NOT null. Proceeding with caution.\")\n            else:\n                print(\"â Config Lock Verified: 'commands' is null.\")\n    except Exception as e:\n        print(f\"â ïļ Warning: Could not verify openclaw.json: {e}\")\n\n    token = os.environ.get(\"TELEGRAM_BOT_TOKEN\")\n    if not token:\n        # Check if DMarket bot config has it\n        try:\n            import yaml\n            with open(\"DMarket-Telegram-Bot-main/config/config.yaml\", \"r\") as f:\n                yaml_config = yaml.safe_load(f)\n                token = yaml_config.get(\"bot\", {}).get(\"token\")\n                if token and \"1234567890\" in token: # check for placeholder\n                    token = None\n        except Exception:\n            pass\n            \n    if not token:\n        print(\"â Error: TELEGRAM_BOT_TOKEN environment variable not set.\")\n        print(\"Please set TELEGRAM_BOT_TOKEN in your environment or .env file.\")\n        return\n\n    # Define the command list (concise descriptions for Telegram limits)\n    commands = [\n        # DMarket Commands\n        {\"command\": \"dm_start\", \"description\": \"âķïļ Start DMarket Bot\"},\n        {\"command\": \"dm_stop\", \"description\": \"âđïļ Stop DMarket Bot\"},\n        {\"command\": \"dm_status\", \"description\": \"ð Stats & Status\"},\n        {\"command\": \"dm_dashboard\", \"description\": \"ð Live Dashboard\"},\n        {\"command\": \"dm_news\", \"description\": \"ð° Market News\"},\n\n        # OpenClaw Native Commands\n        {\"command\": \"new\", \"description\": \"âĻ New Session\"},\n        {\"command\": \"clear\", \"description\": \"ð§đ Clear Context\"},\n        {\"command\": \"search\", \"description\": \"ð Web Search\"},\n        {\"command\": \"settings\", \"description\": \"âïļ Bot Settings\"},\n    ]\n\n    url = f\"https://api.telegram.org/bot{token}/setMyCommands\"\n    data = {\"commands\": json.dumps(commands)}\n\n    print(f\"ð Sending request to Telegram API...\")\n    try:\n        response = requests.post(url, data=data)\n        response.raise_for_status()\n        result = response.json()\n        \n        if result.get(\"ok\"):\n            print(\"â Global menu successfully refreshed!\")\n            print(\"Registered Commands:\")\n            for cmd in commands:\n                print(f\" - /{cmd['command']}: {cmd['description']}\")\n            print(\"\\nFinal Status: Global Menu Configured\")\n        else:\n            print(f\"â Failed to refresh menu: {result.get('description')}\")\n            \n    except Exception as e:\n        print(f\"â Exception occurred: {e}\")\n\nif __name__ == \"__main__\":\n    refresh_menu()\n"}],"isError":false,"timestamp":1771162826482}}
