{"type":"message","id":"40fae9f6","parentId":"6fcb9cf1","timestamp":"2026-02-14T07:02:48.717Z","message":{"role":"toolResult","toolCallId":"read_1771052568700_15","toolName":"read","content":[{"type":"text","text":"# Configuration for development environment\n# Mock configuration for smoke test\n\nbot:\n  token: \"1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456789\"\n  username: \"dmarket_bot\"\n  webhook:\n    url: \"\"\n    secret: \"\"\n\ndmarket:\n  api_url: \"https://api.dmarket.com\"\n  public_key: \"aabbccddeeffgghhiijjkkllmmnnooppqqrrsstt\"\n  secret_key: \"11223344556677889900aabbccddeeffgghhiijj\"\n  rate_limit: 30\n\n# Waxpeer P2P Integration\nwaxpeer:\n  enabled: false\n  api_key: \"\"\n\n# Scanner configuration\nscanner:\n  max_concurrent_scans: 2\n  scan_interval_seconds: 10.0\n  adaptive:\n    enabled: true\n    min_interval: 2.5\n    max_interval: 10.0\n  parallel:\n    enabled: true\n    max_concurrent: 2\n  cleanup:\n    enabled: true\n    max_age_hours: 24\n    interval_minutes: 60\n\ndatabase:\n  url: \"sqlite:///data/dmarket_bot.db\"\n  echo: false\n  pool_size: 5\n  max_overflow: 10\n\nredis:\n  url: \"redis://localhost:6379\"\n\nlogging:\n  level: \"INFO\"\n  file: \"logs/dmarket_bot.log\"\n  format: \"%(asctime)s - %(name)s - %(levelname)s - %(message)s\"\n  rotation: \"1 week\"\n  retention: \"1 month\"\n\nsecurity:\n  allowed_users: []\n  admin_users: []\n\nanalytics:\n  enabled: true\n\nmonitoring:\n  sentry_dsn: \"\"\n  prometheus_enabled: false\n\ncache:\n  ttl: 300\n  max_size: 1000\n\narbitrage_filters:\n  enabled: true\n  min_avg_price: 0.50\n  good_points_percent: 80\n  boost_percent: 150\n  min_sales_volume: 10\n  min_profit_margin: 5.0\n  outlier_threshold: 2.0\n  min_liquidity_score: 60\n  max_time_to_sell_days: 7\n\nmarket_analysis:\n  enabled: true\n  update_interval: 3600\n  top_items_count: 100\n  min_daily_volume: 50\n\ndiversification:\n  enabled: true\n  max_same_items_in_inventory: 5\n  max_single_item_percent: 25\n  min_different_items: 5\n  max_stack_value_percent: 15\n\ngame_strategy:\n  enabled: true\n  weights:\n    tf2: 30\n    csgo: 40\n    rust: 20\n    dota2: 10\n\nwhitelist:\n  enabled: true\n  file_path: \"data/whitelist.json\"\n  priority_only: false\n  buy_max_overpay_percent: 2.0\n\nauto_sell:\n  enabled: true\n  min_margin_percent: 4.0\n  max_margin_percent: 12.0\n  target_margin_percent: 8.0\n  undercut_cents: 1\n  price_check_interval_minutes: 30\n  stop_loss_hours: 48\n  stop_loss_percent: 5.0\n  max_active_sales: 50\n  delay_before_list_seconds: 5\n  pricing_strategy: \"undercut\"\n  dmarket_fee_percent: 7.0\n\nrepricing:\n  enabled: true\n  intervals:\n    - hours: 24\n      action: \"reduce_to_target\"\n    - hours: 48\n      action: \"reduce_to_break_even\"\n    - hours: 72\n      action: \"liquidate\"\n  max_price_cut_percent: 15\n  night_mode:\n    enabled: true\n    start_hour: 2\n    end_hour: 6\n    undercut_multiplier: 2.0\n\npanic_protection:\n  enabled: true\n  threshold_percent: 15\n  check_window_hours: 1\n  action: \"pause\"\n\nblacklist:\n  enabled: true\n  file_path: \"data/blacklist.json\"\n  auto_blacklist_threshold: 3\n  failure_expiry_hours: 24\n  forbidden_keywords:\n    - \"Souvenir\"\n    - \"Well-Worn\"\n    - \"Inscribed Gem\"\n    - \"StatTrak™ Music Kit\"\n    - \"Autograph\"\n\nmarket_sentiment:\n  enabled: true\n  check_interval_minutes: 15\n  panic_sell_threshold: -0.07\n  high_risk_hunt: true\n  speculative_budget_pct: 0.15\n\nsteam_parser:\n  enabled: true\n  cache_ttl: 300\n  max_concurrent_requests: 10\n  request_timeout: 5.0\n  use_proxy: false\n  proxy_url: \"\"\n  requests_per_minute: 30\n  arbitrage:\n    min_profit_percent: 15\n    max_discount_percent: 50\n\nintelligent_hold:\n  enabled: true\n  min_expected_gain: 10\n  max_hold_days: 14\n  profit_take_threshold: 20\n  loss_cut_days: 7\n  loss_cut_threshold: 5\n  event_sensitive_categories:\n    - \"stickers\"\n    - \"capsules\"\n    - \"cases\"\n\nai_training:\n  enabled: true\n  real_prices:\n    default_samples: 500\n    games: [\"csgo\", \"tf2\", \"dota2\", \"rust\"]\n    min_price_usd: 0.50\n    max_price_usd: 1000.0\n  liquid_training:\n    enabled: true\n    liquidity_threshold: 50\n    min_offers_dmarket: 3\n    min_offers_waxpeer: 5\n    whitelist_bonus: 25\n    whitelist_threshold: 40\n    use_waxpeer: true\n    use_steam: true\n  hallucination_protection:\n    enabled: true\n    max_profit_percent: 40\n    outlier_zscore_threshold: 3.0\n  data_paths:\n    market_history: \"data/market_history.csv\"\n    liquid_items: \"data/liquid_items.csv\"\n    model_path: \"data/price_model.pkl\"\n\nmoney_management:\n  enabled: true\n  small_balance_threshold: 100\n  medium_balance_threshold: 500\n  large_balance_threshold: 1000\n  max_item_percent:\n    small: 25\n    medium: 15\n    large: 10\n  min_item_percent: 0.5\n  reserve_percent: 5\n  target_roi:\n    small: 15.0\n    medium: 12.0\n    large: 8.0\n  balance_spike_threshold: 50\n  balance_spike_action: \"pause_and_confirm\"\n\nrate_limit:\n  warning_threshold: 0.9\n  enable_notifications: true\n  base_retry_delay: 1.0\n  max_backoff_time: 60.0\n  max_retry_attempts: 5\n  market_limit: 2\n  trade_limit: 1\n  user_limit: 5\n  balance_limit: 10\n  other_limit: 5\n"}],"isError":false,"timestamp":1771052568716}}
