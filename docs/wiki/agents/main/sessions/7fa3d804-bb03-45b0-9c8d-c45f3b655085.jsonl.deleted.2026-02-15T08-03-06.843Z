{"type":"message","id":"0a6b9e0a","parentId":"43de3c56","timestamp":"2026-02-14T18:40:42.416Z","message":{"role":"toolResult","toolCallId":"read_1771094442393_7","toolName":"read","content":[{"type":"text","text":"\"\"\"\nSAFE BUY WORKFLOW (Pseudo-Lobster Protocol).\nImplements rigid safety checks before any purchase API call.\nThis script is the GATEKEEPER. If it fails, no money moves.\n\"\"\"\n\nimport sys\nimport logging\nimport asyncio\nfrom pathlib import Path\nfrom dotenv import load_dotenv\nimport os\n\n# Setup Environment\nproject_root = Path(r\"D:\\DMarket-Telegram-Bot-main\")\nsys.path.append(str(project_root))\nload_dotenv(project_root / \".env\")\n\n# Configure Logging (Gatekeeper Log)\nlogging.basicConfig(\n    level=logging.INFO,\n    format='%(asctime)s - GATEKEEPER - %(levelname)s - %(message)s',\n    handlers=[\n        logging.FileHandler(project_root / \"logs\" / \"safe_buy.log\"),\n        logging.StreamHandler(sys.stdout)\n    ]\n)\nlogger = logging.getLogger(\"safe_buy\")\n\ntry:\n    from src.api.dmarket import DMarketAPI\n    from src.logic.internal_arbitrage import ArbitrageEngine\nexcept ImportError as e:\n    logger.critical(f\"Import Error: {e}\")\n    sys.exit(1)\n\n# --- CONFIGURATION (HARDCODED SAFETY) ---\nGAME_IDS = {\n    \"csgo\": \"a8db\",\n    \"dota2\": \"9a92\",\n    \"rust\": \"rust\",\n    \"tf2\": \"tf2\"\n}\n\nasync def safe_buy_workflow(\n    game: str,\n    item_title: str,\n    target_price_usd: float,\n    offer_id: str,\n    steam_price_ref: float,\n    wax_price_ref: float\n):\n    \"\"\"\n    The Workflow.\n    1. Validate Inputs.\n    2. Re-Check Market (Live).\n    3. Assert Conditions (Triple Verification).\n    4. Execute Buy (Coins).\n    \"\"\"\n    logger.info(f\"INITIATING SAFE BUY: {item_title} (Target: ${target_price_usd:.2f})\")\n\n    # 1. INPUT VALIDATION (Type Safety)\n    try:\n        assert isinstance(target_price_usd, float), \"Price must be float\"\n        assert target_price_usd > 0.01, \"Price too low\"\n        assert game in GAME_IDS, f\"Invalid Game ID: {game}\"\n        assert len(offer_id) > 5, \"Invalid Offer ID\"\n    except AssertionError as e:\n        logger.error(f\"INPUT VALIDATION FAILED: {e}\")\n        sys.exit(1)\n\n    # 2. LIVE MARKET CHECK (Race Condition Prevention)\n    # In a real scenario, we'd fetch the specific offer again to ensure it's still there\n    # and the price hasn't changed.\n    # For this implementation, we assume the data passed is fresh from the scanner.\n    \n    # 3. TRIPLE VERIFICATION (The \"Lobster\" Asserts)\n    # We re-run the logic engine to be 100% sure.\n    engine = ArbitrageEngine(balance=50.0) # Balance handled dynamically usually\n    decision, reason = engine.check_opportunity(\n        item_name=item_title,\n        price_dm=target_price_usd,\n        price_steam=steam_price_ref,\n        price_wax=wax_price_ref\n    )\n\n    if decision != \"BUY\":\n        logger.warning(f\"LOGIC ASSERT FAILED: {reason}\")\n        sys.exit(1) # TERMINATE\n\n    # 4. EXECUTION (The only place API is called)\n    public_key = os.getenv(\"DMARKET_PUBLIC_KEY\")\n    secret_key = os.getenv(\"DMARKET_SECRET_KEY\")\n    \n    if os.getenv(\"DRY_RUN\", \"true\").lower() == \"true\":\n        logger.info(\"DRY RUN: Buy Verified but NOT Executed.\")\n        sys.exit(0)\n\n    try:\n        api = DMarketAPI(public_key, secret_key)\n        \n        # CONVERT TO CENTS (Vital Fix from Docs)\n        price_coins = int(target_price_usd * 100)\n        \n        logger.info(f\"EXECUTING BUY API: {offer_id} @ {price_coins} coins\")\n        response = await api.buy_item(offer_id, price_coins, game=game)\n        \n        if response.get(\"status\") == \"success\" or \"txId\" in response:\n             logger.info(f\"BUY SUCCESS: {response}\")\n        else:\n             logger.error(f\"BUY API ERROR: {response}\")\n             \n        await api.close()\n\n    except Exception as e:\n        logger.critical(f\"EXECUTION ERROR: {e}\")\n        sys.exit(1)\n\nif __name__ == \"__main__\":\n    # CLI Interface for OpenClaw to call\n    # Usage: python safe_buy.py <game> <title> <price> <offer_id> <steam_ref> <wax_ref>\n    if len(sys.argv) < 7:\n        print(\"Usage: python safe_buy.py <game> <title> <price> <offer_id> <steam_ref> <wax_ref>\")\n        sys.exit(1)\n        \n    asyncio.run(safe_buy_workflow(\n        game=sys.argv[1],\n        item_title=sys.argv[2],\n        target_price_usd=float(sys.argv[3]),\n        offer_id=sys.argv[4],\n        steam_price_ref=float(sys.argv[5]),\n        wax_price_ref=float(sys.argv[6])\n    ))\n"}],"isError":false,"timestamp":1771094442415}}
