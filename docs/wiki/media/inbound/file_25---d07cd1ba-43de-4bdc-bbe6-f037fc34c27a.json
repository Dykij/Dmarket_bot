    "overview": {
        "description": "OpenClaw is a personal, single-user AI assistant that feels local, fast, and always-on. It answers on channels you already use and can speak, listen, browse, and execute tasks on your behalf. The Gateway is the control plane -- the product is the assistant.",
        "key_principles": [
            "Self-hosted and local-first -- runs entirely on user-controlled infrastructure",
            "Persistent and always-on -- remembers past interactions and schedules tasks",
            "Full system access -- reads/writes files, runs shell commands, controls browsers",
            "Model-agnostic -- supports Claude, GPT, Gemini, local LLMs (Ollama)",
            "Extensible and modular -- custom skills, tools, and integrations",
            "Multi-channel -- single assistant across all messaging platforms"
        ],
        "highlights": [
            "Local-first Gateway -- single control plane for sessions, channels, tools, and events",
            "Multi-channel inbox -- WhatsApp, Telegram, Slack, Discord, Google Chat, Signal, BlueBubbles (iMessage), iMessage (legacy), Microsoft Teams, Matrix, Zalo, Zalo Personal, WebChat, macOS, iOS/Android",
            "Multi-agent routing -- route inbound channels/accounts/peers to isolated agents",
            "Voice Wake + Talk Mode -- always-on speech for macOS/iOS/Android with ElevenLabs",
            "Live Canvas -- agent-driven visual workspace with A2UI",
            "First-class tools -- browser, canvas, nodes, cron, sessions, and Discord/Slack actions",
            "Companion apps -- macOS menu bar app + iOS/Android nodes",
            "Onboarding + skills -- wizard-driven setup with bundled/managed/workspace skills"
        ]
    },
    "architecture": {
        "description": "OpenClaw uses a hub-and-spoke architecture centered on the Gateway control plane.",
        "diagram": "Channels (WhatsApp/Telegram/Slack/Discord/etc.) -> Gateway (ws://127.0.0.1:18789) -> [Pi agent (RPC), CLI, WebChat UI, macOS app, iOS/Android nodes]",
        "components": {
            "gateway": {
                "description": "WebSocket control plane for sessions, channels, tools, and events. Written in TypeScript. Runs locally on ws://127.0.0.1:18789.",
                "features": [
                    "Session management and routing",
                    "Channel connections and message normalization",
                    "Tool execution orchestration",
                    "Presence and typing indicators",
                    "Cron jobs and webhooks",
                    "Control UI and WebChat hosting",
                    "Health checks and diagnostics (openclaw doctor)",
                    "Tailscale Serve/Funnel integration for remote access"
                ],
                "url": "https://docs.openclaw.ai/gateway"
            },
            "agent_runtime": {
                "description": "Pi agent runtime in RPC mode with tool streaming and block streaming. Interprets intent, plans actions, remembers past events, and orchestrates reasoning.",
                "features": [
                    "Dynamic system prompt building",
                    "API key management",
                    "Context window management",
                    "Tool streaming and block streaming",
                    "Lane Queue for serial execution (prevents race conditions)",
                    "Model failover support"
                ],
                "url": "https://docs.openclaw.ai/concepts/agent"
            },
            "memory_system": {
                "description": "Persistent, structured memory stored as plain Markdown and YAML files.",
                "tiers": [
                    {
                        "name": "JSONL Transcripts",
                        "description": "Factual audit of all events and interactions"
                    },
                    {
                        "name": "Markdown Memory (MEMORY.md)",
                        "description": "Curated summaries, experiences, and distilled knowledge for long-term retention"
                    }
                ],
                "features": [
                    "Inspectable, backupable plain text files",
                    "Consistent behavior across sessions",
                    "User context and preference retention"
                ]
            },
            "skill_system": {
                "description": "Modular code packages extending agent capabilities. Uses SKILL.md files combining YAML frontmatter with natural language instructions.",
                "types": [
                    "Bundled skills (included with OpenClaw)",
                    "Managed skills (maintained by community)",
                    "Workspace skills (user-created)"
                ],
                "registry": {
                    "name": "ClawHub",
                    "url": "https://clawhub.com",
                    "description": "Minimal skill registry for automatic discovery and pull-in of new skills"
                },
                "url": "https://docs.openclaw.ai/tools/skills"
            },
            "execution_layer": {
                "description": "Provides the interface to perform tasks with the operating system.",
                "capabilities": [
                    "Shell command execution",
                    "File management (read, write, edit)",
                    "Browser automation via Chrome DevTools Protocol (CDP)",
                    "Script execution",
                    "Process management"
                ]
            }
        }
    },
    "installation": {
        "prerequisites": {
            "node": "Node.js >= 22",
            "ram": "1 GB minimum (4 GB recommended for stable npm builds)",
            "platforms": [
                "macOS",
                "Linux",
                "Windows (via WSL2)"
            ],
            "port": 18789,
            "requirements": [
                "An API key for an LLM provider",
                "A messaging platform account"
            ]
        },
        "methods": {
            "scripted_installer": {
                "description": "Fastest option. Auto-detects OS, checks Node.js, launches onboarding wizard.",
                "commands": {
                    "macos_linux": "curl -fsSL https://openclaw.ai/install.sh | bash",
                    "windows_powershell": "iwr -useb https://openclaw.ai/install.ps1 | iex"
                }
            },
            "npm_global": {
                "description": "Suitable for systems running multiple Node.js applications.",
                "commands": [
                    "npm install -g openclaw@latest",
                    "openclaw onboard --install-daemon"
                ]
            },
            "from_source": {
                "description": "For development. Prefer pnpm for builds from source.",
                "commands": [
                    "git clone https://github.com/openclaw/openclaw.git",
                    "cd openclaw",
                    "pnpm install",
                    "pnpm ui:build",
                    "pnpm build",
                    "pnpm openclaw onboard --install-daemon",
                    "pnpm gateway:watch  # Dev loop with auto-reload"
                ]
            },
            "docker": {
                "description": "Ideal for isolation and reproducibility.",
                "url": "https://docs.openclaw.ai/install/docker"
            },
            "nix": {
                "description": "Declarative configuration for NixOS.",
                "url": "https://github.com/openclaw/nix-openclaw"
            }
        },
        "onboarding_wizard": {
            "command": "openclaw onboard",
            "steps": [
                "Accept disclaimer",
                "Choose onboarding mode (Quick Start recommended)",
                "Select model provider and enter API key",
                "Connect messaging platforms (channels)",
                "Get and pair your user ID",
                "Configure skills (optional)",
                "Choose UI (Web Control UI or Terminal TUI)",
                "Personalize assistant name and personality"
            ]
        },
        "development_channels": {
            "stable": "Tagged releases (vYYYY.M.D), npm dist-tag 'latest'",
            "beta": "Prerelease tags (vYYYY.M.D-beta.N), npm dist-tag 'beta'",
            "dev": "Moving head of main branch, npm dist-tag 'dev'",
            "switch_command": "openclaw update --channel stable|beta|dev"
        },
        "updating": {
            "guide_url": "https://docs.openclaw.ai/install/updating",
            "diagnostic_command": "openclaw doctor"
        }
    },
