    "security": {
        "description": "OpenClaw connects to real messaging surfaces. Treat inbound DMs as untrusted input.",
        "url": "https://docs.openclaw.ai/gateway/security",
        "dm_access_defaults": {
            "policy": "pairing",
            "description": "Unknown senders receive a short pairing code and the bot does not process their message.",
            "approval_command": "openclaw pairing approve <channel> <code>",
            "public_dms": "Require explicit opt-in: set dmPolicy='open' and include '*' in channel allowlist"
        },
        "sandbox": {
            "description": "Group/channel safety via Docker sandboxes for non-main sessions.",
            "config": "agents.defaults.sandbox.mode: 'non-main'",
            "allowlist_tools": [
                "bash",
                "process",
                "read",
                "write",
                "edit",
                "sessions_list",
                "sessions_history",
                "sessions_send",
                "sessions_spawn"
            ],
            "denylist_tools": [
                "browser",
                "canvas",
                "nodes",
                "cron",
                "discord",
                "gateway"
            ]
        },
        "lane_queue": {
            "description": "Enforces serial execution by default. Tasks within a session are processed one by one. Parallelism is an explicit opt-in for low-risk tasks only. Prevents race conditions."
        },
        "elevated_access": {
            "description": "Per-session elevated bash access via /elevated on|off command.",
            "gateway_persistence": "sessions.patch WS method (alongside thinkingLevel, verboseLevel, model, sendPolicy, groupActivation)"
        },
        "browser_isolation": {
            "description": "Browser control uses an independent Chromium instance isolated from user's personal browser."
        },
        "diagnostic_command": "openclaw doctor (surfaces risky/misconfigured DM policies)"
    },
