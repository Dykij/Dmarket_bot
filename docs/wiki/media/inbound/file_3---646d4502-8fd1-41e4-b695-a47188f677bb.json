    {
      "id": "overview",
      "title": "What is PowerShell?",
      "content": {
        "description": "PowerShell is a cross-platform task automation solution made up of a command-line shell, a scripting language, and a configuration management framework. Runs on Windows, Linux, and macOS.",
        "shell_features": [
          "Robust command-line history",
          "Tab completion and command prediction (PSReadLine)",
          "Command and parameter aliases",
          "Pipeline for chaining commands",
          "In-console help system (similar to Unix man pages)",
          "Accepts and returns .NET objects (not just text)"
        ],
        "scripting_features": [
          "Extensible through functions, classes, scripts, and modules",
          "Extensible formatting system for output",
          "Extensible type system for dynamic types",
          "Built-in support for CSV, JSON, and XML",
          "Built on .NET Common Language Runtime (CLR)"
        ]
      }
    },
