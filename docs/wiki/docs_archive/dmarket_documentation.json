    {
      "id": "authentication",
      "title": "Authentication (Signature v1)",
      "content": {
        "description": "Requests require 3 headers: X-Api-Key (public key hex), X-Sign-Date (timestamp), X-Request-Sign (SHA256/ed25519 signature).",
        "signature_steps": [
          "1. Build non-signed string: (HTTP Method) + (Route path + HTTP query params) + (body string) + (timestamp)",
          "2. Sign with NACL using your secret key (ed25519)",
          "3. Encode the result string with hex",
          "4. Add signature to X-Request-Sign header (prefix: dmar ed25519 signature)"
        ],
        "tools_repo": "https://github.com/dmarket/dm-trading-tools",
        "api_keys_settings": "https://dmarket.com/faq#tradingAPI"
      }
    },
    {
      "id": "account",
      "title": "Account",
      "content": {
        "endpoints": [
          {
            "method": "GET",
            "path": "/account/v1/user",
            "summary": "Getting general user profile information."
          },
          {
            "method": "GET",
            "path": "/account/v1/balance",
            "summary": "Getting current USD & DMC balance (format: coins/cents)."
          }
        ]
      }
    },
    {
      "id": "sell_items",
      "title": "Sell Items",
      "content": {
        "endpoints": [
          {
            "method": "POST",
            "path": "/marketplace-api/v1/deposit-assets",
            "summary": "Transfer items from 3rd party inventory (e.g. Steam) to DMarket inventory."
          },
          {
            "method": "GET",
            "path": "/marketplace-api/v1/deposit-status/{DepositID}",
            "summary": "Get information about current deposit transfers."
          },
          {
            "method": "GET",
            "path": "/marketplace-api/v1/user-offers",
            "summary": "Get user's offers list for management (remove/change price). Price in USD."
          },
          {
            "method": "POST",
            "path": "/marketplace-api/v1/user-offers/create",
            "summary": "Batch offers creation. Asset is locked and offer appears in Market. Price in USD."
          },
          {
            "method": "POST",
            "path": "/marketplace-api/v1/user-offers/edit",
            "summary": "Change sale price for existing offers. Price in USD."
          }
        ],
        "game_ids": {
          "CS:GO": "a8db",
          "Team Fortress 2": "tf2",
          "Dota 2": "9a92",
          "Rust": "rust"
        }
      }
    },
    {
      "id": "buy_items",
      "title": "Buy Items",
      "content": {
        "endpoints": [
          {
            "method": "GET",
            "path": "/exchange/v1/offers-by-title",
            "summary": "Get all offers for a single item title. Price in USD."
          },
          {
            "method": "GET",
            "path": "/price-aggregator/v1/aggregated-prices",
            "summary": "Get best market prices grouped by item title."
          },
          {
            "method": "POST",
            "path": "/exchange/v1/offers/buy",
            "summary": "Buy selected offers. Price in coins (cents for USD)."
          },
          {
            "method": "GET",
            "path": "/marketplace-api/v1/user-offers/closed",
            "summary": "Get user's closed sell offers. Price in USD."
          }
        ]
      }
    },
    {
      "id": "inventory",
      "title": "Inventory/Items",
      "content": {
        "endpoints": [
          {
            "method": "GET",
            "path": "/marketplace-api/v1/user-inventory",
            "summary": "Get user inventory (Steam + DMarket merged). Price in USD."
          },
          {
            "method": "POST",
            "path": "/marketplace-api/v1/user-inventory/sync",
            "summary": "Sync DMarket inventory with Steam data."
          },
          {
            "method": "POST",
            "path": "/exchange/v1/withdraw-assets",
            "summary": "Withdraw assets from DMarket."
          },
          {
            "method": "GET",
            "path": "/exchange/v1/user/items",
            "summary": "Get user inventory filtered by game (excludes items on sale)."
          }
        ]
      }
    },
